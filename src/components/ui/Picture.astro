---
import { Picture as AstroPicture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  src?: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  widths,
  sizes,
  loading = 'lazy',
  fetchpriority,
  class: className,
} = Astro.props;

// Validate and provide default alt text if needed
const validAlt = alt && String(alt).trim() ? String(alt).trim() : 'Gambar';
const hasSrc = src !== undefined && src !== null && (typeof src !== 'string' || String(src).trim() !== '');
const isLocalAsset = hasSrc && typeof src !== 'string';

// When a caller declares a responsive `sizes` but no explicit width list, emit
// a sensible srcset. All shipped assets are ≥1448px wide, so these stay within
// the source (Astro errors if a width exceeds the original).
const resolvedWidths = widths ?? (sizes ? [400, 800, 1200] : undefined);
---

{
  hasSrc ? (
    isLocalAsset ? (
      <AstroPicture
        src={src as ImageMetadata}
        alt={validAlt}
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        widths={resolvedWidths}
        sizes={sizes}
        loading={loading}
        fetchpriority={fetchpriority}
        class={className}
      />
    ) : (
      <img
        src={src as string}
        alt={validAlt}
        width={width}
        height={height}
        loading={loading}
        decoding="async"
        fetchpriority={fetchpriority}
        class={className}
      />
    )
  ) : (
    <div class={className} aria-hidden="true" />
  )
}
