---
import Picture from '@/components/ui/Picture.astro';
import Section from '@/components/ui/Section.astro';

export interface Props {
  images: Array<{ src: string; alt: string; caption?: string }>;
}

const { images } = Astro.props;
---

<Section
  id="gallery"
  eyebrow="Dalam konteks"
  title="Contoh penggunaan produk di acara nyata."
  subtitle="Galeri responsif untuk foto produk dan dokumentasi acara."
  container="xl"
>
  <div class="gallery">
    {
      images.map((image, index) => (
        <figure class:list={['gallery__item', `gallery__item--${index + 1}`]}>
          <Picture
            src={image.src}
            alt={image.alt}
            width={1200}
            height={900}
            sizes="(max-width: 760px) 100vw, 50vw"
            class="gallery__image"
          />
          {image.caption && <figcaption><span>{String(index + 1).padStart(2, '0')}</span>{image.caption}</figcaption>}
        </figure>
      ))
    }
  </div>
</Section>

<style>
  .gallery {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-xl);
  }

  .gallery__item {
    margin: 0;
  }

  .gallery__item--1 {
    grid-row: span 2;
  }

  :global(.gallery__image) {
    width: 100%;
    height: 22rem;
    object-fit: cover;
    border-radius: var(--radius-xl);
    border: 1px solid var(--glass-border);
    filter: saturate(0.78);
  }

  .gallery__item--1 :global(.gallery__image) {
    height: 49rem;
  }

  figcaption {
    display: flex;
    gap: var(--space-md);
    padding-top: var(--space-sm);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  figcaption span {
    color: var(--color-accent);
    font-family: var(--font-mono);
  }

  @media (max-width: 760px) {
    .gallery {
      grid-template-columns: 1fr;
    }

    .gallery__item--1 {
      grid-row: auto;
    }

    :global(.gallery__image),
    .gallery__item--1 :global(.gallery__image) {
      height: min(30rem, 75vh);
    }
  }
</style>
