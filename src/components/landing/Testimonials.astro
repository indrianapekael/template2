---
import Section from '@/components/ui/Section.astro';

export interface Props {
  testimonials: Array<{
    name: string;
    role: string;
    company?: string;
    content: string;
    avatar?: string;
    rating?: number;
  }>;
}

const { testimonials } = Astro.props;
---

<Section id="stories" eyebrow="Laporan Lapangan" title="Dipakai dan direkomendasikan." container="xl">
  <div class="testimonials">
    {
      testimonials.map((testimonial, index) => (
        <figure class="testimonial">
          <div class="testimonial__meta">
            <span>{String(index + 1).padStart(2, '0')}</span>
            {testimonial.rating && (
              <span class="testimonial__rating" aria-label={`${testimonial.rating} out of 5 stars`}>
                {'★'.repeat(testimonial.rating)}
              </span>
            )}
          </div>
          <blockquote>“{testimonial.content}”</blockquote>
          <figcaption>
            <span class="testimonial__initials" aria-hidden="true">
              {testimonial.name.split(' ').map((part) => part[0]).join('').slice(0, 2)}
            </span>
            <span>
              <strong>{testimonial.name}</strong>
              <small>{testimonial.role}{testimonial.company ? `, ${testimonial.company}` : ''}</small>
            </span>
          </figcaption>
        </figure>
      ))
    }
  </div>
</Section>

<style>
  .testimonials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
  }

  .testimonial {
    display: flex;
    flex-direction: column;
    min-height: 27rem;
    margin: 0;
    padding: var(--space-xl);
    border-right: 1px solid var(--glass-border);
  }

  .testimonial:last-child {
    border-right: 0;
  }

  .testimonial__meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .testimonial__rating {
    color: var(--color-accent);
    letter-spacing: 0.08em;
  }

  blockquote {
    margin: auto 0;
    font-size: var(--text-xl);
    line-height: 1.5;
    letter-spacing: -0.02em;
  }

  figcaption {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .testimonial__initials {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--color-accent-glass);
    color: var(--color-accent);
    font-size: var(--text-xs);
    font-weight: 800;
  }

  figcaption > span:last-child {
    display: grid;
  }

  small {
    color: var(--color-text-muted);
  }

  @media (max-width: 800px) {
    .testimonials {
      grid-template-columns: 1fr;
    }

    .testimonial {
      min-height: 21rem;
      border-right: 0;
      border-bottom: 1px solid var(--glass-border);
    }

    .testimonial:last-child {
      border-bottom: 0;
    }
  }
</style>
