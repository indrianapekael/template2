---
import Button from '@/components/ui/Button.astro';
import GlassCard from '@/components/ui/GlassCard.astro';
import Section from '@/components/ui/Section.astro';

export interface Props {
  plans: Array<{
    name: string;
    price: string;
    period?: string;
    description: string;
    features: string[];
    highlighted: boolean;
    cta: { text: string; href: string };
    coverImage?: string;
    slug?: string;
  }>;
}

const { plans } = Astro.props;
---

<Section
  id="pricing"
  eyebrow="Pilihan Paket"
  title="Pilih paket awal Anda."
  subtitle="Pilih paket sesuai kebutuhan acara. Pembelian dilakukan melalui tautan eksternal."
  container="xl"
>
  <div class="pricing-grid">
    {
      plans.map((plan) => (
        <GlassCard padding="lg" radius="xl" class:list={['pricing-card', { 'pricing-card--featured': plan.highlighted }]}> 
          {plan.coverImage && <img class="pricing-card__image" src={plan.coverImage} alt={plan.name || 'Gambar paket'} loading="lazy" />}

          <div class="pricing-card__heading">
            <div>
              <p class="pricing-card__name">{plan.name}</p>
              {plan.highlighted && <span class="pricing-card__label">Direkomendasikan</span>}
            </div>
            <p class="pricing-card__price">
              {plan.price}
              {plan.period && <span> / {plan.period}</span>}
            </p>
          </div>
          <p class="pricing-card__description">{plan.description}</p>
          <ul>
            {plan.features.map((feature) => <li><span aria-hidden="true">✓</span>{feature}</li>)}
          </ul>
          <Button href={plan.cta.href} external variant={plan.highlighted ? 'solid' : 'outline'} fullWidth>
            {plan.cta.text}
          </Button>
        </GlassCard>
      ))
    }
  </div>
</Section>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    align-items: stretch;
    gap: var(--space-lg);
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
  }

  .pricing-card--featured {
    border-color: color-mix(in srgb, var(--color-accent) 55%, transparent);
    transform: translateY(-1.25rem);
  }

  .pricing-card__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-lg);
    border: 1px solid var(--glass-border);
  }

  .pricing-card__heading {
    min-height: 8.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-lg);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--glass-border);
  }

  .pricing-card__name {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 700;
  }

  .pricing-card__label {
    display: inline-block;
    margin-top: var(--space-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .pricing-card__price {
    margin: 0;
    font-size: var(--text-4xl);
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  .pricing-card__price span {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: normal;
  }

  .pricing-card__description {
    min-height: 5.5rem;
    margin: var(--space-xl) 0 0;
    color: var(--color-text-muted);
  }

  ul {
    display: grid;
    gap: var(--space-sm);
    list-style: none;
    padding: var(--space-lg) 0 var(--space-xl);
    margin: 0 0 auto;
  }

  li {
    display: flex;
    gap: var(--space-sm);
    margin: 0;
  }

  li span {
    color: var(--color-accent);
  }

  @media (max-width: 860px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card--featured {
      transform: none;
    }
  }
</style>
