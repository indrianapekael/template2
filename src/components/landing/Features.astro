---
import GlassCard from '@/components/ui/GlassCard.astro';
import Section from '@/components/ui/Section.astro';

export interface Props {
  features: Array<{
    title: string;
    description: string;
    icon?: string;
    image?: string;
  }>;
}

const { features } = Astro.props;
---

<Section
  id="features"
  eyebrow="Koleksi"
  title="Dirancang untuk berguna."
  subtitle="Objek yang dipilih untuk fungsi dan kualitas." 
  align="left"
  container="xl"
>
  <div class="features-grid">
    {
      features.map((feature, index) => (
        <GlassCard padding="lg" radius="xl" class="feature-card">
          <div class="feature-card__top">
            <span class="feature-card__number">{String(index + 1).padStart(2, '0')}</span>
            <span class="feature-card__glyph" aria-hidden="true">{feature.icon ?? '✦'}</span>
          </div>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </GlassCard>
      ))
    }
  </div>
</Section>

<style>
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .feature-card {
    min-height: 20rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .feature-card:nth-child(2) {
    transform: translateY(2.5rem);
  }

  .feature-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .feature-card__number {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .feature-card__glyph {
    display: grid;
    place-items: center;
    width: 3.25rem;
    height: 3.25rem;
    border: 1px solid var(--glass-border);
    border-radius: 50%;
    color: var(--color-accent);
    font-size: var(--text-xl);
    background: var(--color-accent-glass);
  }

  h3 {
    margin: auto 0 var(--space-md);
    font-size: var(--text-2xl);
    letter-spacing: -0.03em;
  }

  p {
    margin: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 800px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .feature-card,
    .feature-card:nth-child(2) {
      min-height: 16rem;
      transform: none;
    }
  }
</style>
