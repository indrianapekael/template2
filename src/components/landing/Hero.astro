---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Picture from '@/components/ui/Picture.astro';

export interface Props {
  hero: {
    title: string;
    subtitle: string;
    description: string;
    cta: {
      primary: { text: string; href: string };
      secondary?: { text: string; href: string };
    };
    image?: string;
  };
}

const { hero } = Astro.props;
---

<section class="landing-hero">
  <Container size="xl" class="landing-hero__inner">
    <div class="landing-hero__copy">
      <p class="landing-hero__eyebrow">{hero.subtitle}</p>
      <h1>{hero.title}</h1>
      <p class="landing-hero__description">{hero.description}</p>
      <div class="landing-hero__actions">
        <Button href={hero.cta.primary.href} external variant="solid" size="md">
          {hero.cta.primary.text}
          <span aria-hidden="true">↗</span>
        </Button>
        {
          hero.cta.secondary && (
            <Button href={hero.cta.secondary.href} external variant="outline" size="md">
              {hero.cta.secondary.text}
            </Button>
          )
        }
      </div>
      <p class="landing-hero__note">Tautan paket dan detail produk. Cek opsi paket langsung di halaman produk.</p>
    </div>

    <div class="landing-hero__visual" aria-hidden={!hero.image}>
      <span class="landing-hero__index">01 / PERLENGKAPAN SEMINAR</span>
      {
        hero.image ? (
          <Picture
            src={hero.image}
            alt={hero.title || 'Perlengkapan seminar profesional'}
            width={960}
            height={1200}
            loading="eager"
            fetchpriority="high"
            class="landing-hero__image"
          />
        ) : (
          <div class="landing-hero__placeholder" />
        )
      }
      <div class="landing-hero__caption">
        <span>Perlengkapan acara</span>
        <span>Dibuat untuk bertahan</span>
      </div>
    </div>
  </Container>
</section>

<style>
  .landing-hero {
    padding-block: clamp(4rem, 10vw, 8rem);
    overflow: hidden;
  }

  .landing-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(20rem, 0.75fr);
    align-items: center;
    gap: clamp(3rem, 8vw, 8rem);
  }

  .landing-hero__copy {
    position: relative;
    z-index: 1;
  }

  .landing-hero__eyebrow,
  .landing-hero__index,
  .landing-hero__note {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .landing-hero__eyebrow {
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
  }

  h1 {
    max-width: 12ch;
    margin-bottom: var(--space-xl);
    font-size: clamp(3.5rem, 8vw, 7.4rem);
    line-height: 0.91;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  .landing-hero__description {
    max-width: 38rem;
    color: var(--color-text-muted);
    font-size: var(--text-xl);
    line-height: 1.55;
  }

  .landing-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }

  .landing-hero__note {
    margin: var(--space-lg) 0 0;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
  }

  .landing-hero__visual {
    position: relative;
    min-height: 37rem;
    padding: var(--space-md);
    border: 1px solid var(--glass-border);
    border-radius: clamp(1.5rem, 4vw, 3rem);
    background: color-mix(in srgb, var(--color-surface) 74%, transparent);
    box-shadow: var(--glass-shadow);
    transform: rotate(2.5deg);
  }

  .landing-hero__visual::before {
    content: '';
    position: absolute;
    width: 13rem;
    height: 13rem;
    top: -3rem;
    right: -4rem;
    border-radius: 50%;
    background: var(--aurora-4);
    filter: blur(55px);
    opacity: 0.25;
    z-index: -1;
  }

  .landing-hero__index {
    display: block;
    padding: var(--space-sm) var(--space-sm) var(--space-md);
    color: var(--color-text-muted);
  }

  :global(.landing-hero__image) {
    width: 100%;
    height: 30rem;
    object-fit: cover;
    border-radius: calc(clamp(1.5rem, 4vw, 3rem) - var(--space-md));
    filter: saturate(0.72) contrast(1.06);
  }

  .landing-hero__placeholder {
    height: 30rem;
    border-radius: 2rem;
    background: linear-gradient(145deg, var(--aurora-2), var(--aurora-1));
  }

  .landing-hero__caption {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-sm) var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  @media (max-width: 860px) {
    .landing-hero__inner {
      grid-template-columns: 1fr;
    }

    .landing-hero__visual {
      width: min(100%, 34rem);
      min-height: auto;
      margin-inline: auto;
      transform: rotate(1deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-hero__visual {
      transform: none;
    }
  }

  @media (prefers-reduced-transparency: reduce) {
    .landing-hero__visual {
      background: var(--color-surface);
    }
  }
</style>
