---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';

export interface Props {
  cta: {
    title: string;
    description: string;
    button: { text: string; href: string };
  };
}

const { cta } = Astro.props;
---

<section class="final-cta">
  <Container size="xl">
    <div class="final-cta__panel">
      <span class="final-cta__mark" aria-hidden="true">✦</span>
      <p>Selanjutnya</p>
      <h2>{cta.title}</h2>
      <div class="final-cta__footer">
        <p>{cta.description}</p>
        <Button href={cta.button.href} external variant="solid" size="md">
          {cta.button.text}
          <span aria-hidden="true">↗</span>
        </Button>
      </div>
    </div>
  </Container>
</section>

<style>
  .final-cta {
    padding-block: clamp(4rem, 10vw, 8rem);
  }

  .final-cta__panel {
    position: relative;
    overflow: hidden;
    padding: clamp(2rem, 7vw, 6rem);
    border: 1px solid var(--glass-border);
    border-radius: clamp(1.5rem, 4vw, 3rem);
    background:
      radial-gradient(circle at 85% 10%, color-mix(in srgb, var(--aurora-2) 30%, transparent), transparent 35%),
      color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  .final-cta__mark {
    position: absolute;
    top: 1rem;
    right: 2rem;
    color: var(--color-accent);
    font-size: clamp(5rem, 15vw, 12rem);
    opacity: 0.18;
  }

  .final-cta__panel > p {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  h2 {
    max-width: 12ch;
    margin-block: var(--space-xl) var(--space-3xl);
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .final-cta__footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-xl);
  }

  .final-cta__footer > p {
    max-width: 35rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }

  @media (max-width: 680px) {
    .final-cta__footer {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (prefers-reduced-transparency: reduce) {
    .final-cta__panel {
      background: var(--color-surface);
    }
  }
</style>
