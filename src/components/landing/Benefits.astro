---
import Container from '@/components/ui/Container.astro';

export interface Props {
  benefits: Array<{ title: string; description: string; icon?: string }>;
}

const { benefits } = Astro.props;
---

<section class="benefits" aria-labelledby="benefits-title">
  <Container size="xl">
    <div class="benefits__intro">
      <p>Mengapa penting</p>
      <h2 id="benefits-title">Cara yang lebih rapi untuk menyelenggarakan acara yang lebih baik.</h2>
    </div>
    <ol class="benefits__list">
      {
        benefits.map((benefit, index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h3>{benefit.title}</h3>
              <p>{benefit.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </Container>
</section>

<style>
  .benefits {
    padding-block: clamp(5rem, 12vw, 10rem);
  }

  .benefits :global(.container) {
    display: grid;
    grid-template-columns: minmax(15rem, 0.8fr) minmax(20rem, 1.2fr);
    gap: clamp(3rem, 9vw, 9rem);
  }

  .benefits__intro {
    position: sticky;
    top: 8rem;
    align-self: start;
  }

  .benefits__intro > p {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .benefits__intro h2 {
    font-size: clamp(2.5rem, 5vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .benefits__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .benefits__list li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-lg);
    padding-block: var(--space-2xl);
    margin: 0;
    border-top: 1px solid var(--glass-border);
  }

  .benefits__list li:last-child {
    border-bottom: 1px solid var(--glass-border);
  }

  .benefits__list span {
    padding-top: 0.35rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .benefits__list h3 {
    margin-bottom: var(--space-sm);
    font-size: var(--text-2xl);
  }

  .benefits__list p {
    max-width: 36rem;
    margin: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 760px) {
    .benefits :global(.container) {
      grid-template-columns: 1fr;
    }

    .benefits__intro {
      position: static;
    }
  }
</style>
