---
export interface Props {
  variant?: 'default' | 'solid' | 'minimal';
  padding?: 'none' | 'sm' | 'md' | 'lg' | 'xl';
  radius?: 'none' | 'sm' | 'md' | 'lg' | 'xl';
  className?: string;
  as?: keyof HTMLElementTagNameMap;
}

const {
  variant = 'default',
  padding = 'lg',
  radius = 'lg',
  className = '',
  as: Element = 'div'
} = Astro.props;

const paddingMap: Record<string, string> = {
  none: '0',
  sm: 'var(--space-sm)',
  md: 'var(--space-md)',
  lg: 'var(--space-lg)',
  xl: 'var(--space-xl)'
};

const radiusMap: Record<string, string> = {
  none: '0',
  sm: 'var(--radius-sm)',
  md: 'var(--radius-md)',
  lg: 'var(--radius-lg)',
  xl: 'var(--radius-xl)'
};

const paddingValue = paddingMap[padding];
const radiusValue = radiusMap[radius];
---

<Element
  class={`glass-panel glass-panel--${variant} ${className}`}
  style={`--panel-padding: ${paddingValue}; --panel-radius: ${radiusValue};`}
>
  <slot />
</Element>

<style>
  .glass-panel {
    position: relative;
    padding: var(--panel-padding);
    border-radius: var(--panel-radius);
    overflow: hidden;
  }

  /* Default variant */
  .glass-panel--default {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    border: 1px solid var(--glass-border);
    box-shadow:
      var(--glass-shadow),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.1);
  }

  /* Solid variant for better text readability */
  .glass-panel--solid {
    background: var(--glass-bg-solid);
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
  }

  /* Minimal variant */
  .glass-panel--minimal {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Subtle noise texture overlay */
  .glass-panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 35px,
        rgba(255, 255, 255, 0.01) 35px,
        rgba(255, 255, 255, 0.01) 70px
      );
    pointer-events: none;
    opacity: 0.4;
    z-index: 0;
  }

  /* Ensure content is above the texture */
  .glass-panel > * {
    position: relative;
    z-index: 1;
  }

  /* Dark mode adjustments */
  [data-theme="dark"] .glass-panel--default {
    background: rgba(0, 0, 0, 0.2);
  }

  [data-theme="dark"] .glass-panel--solid {
    background: rgba(0, 0, 0, 0.7);
  }

  [data-theme="dark"] .glass-panel--minimal {
    background: rgba(0, 0, 0, 0.1);
    border-color: rgba(255, 255, 255, 0.03);
  }

  /* Accessibility: Reduced transparency */
  @media (prefers-reduced-transparency: reduce) {
    .glass-panel--default,
    .glass-panel--solid {
      background: var(--color-surface);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }

    .glass-panel::before {
      display: none;
    }
  }

  /* No backdrop-filter support fallback */
  @supports not (backdrop-filter: blur(1px)) {
    .glass-panel--default {
      background: rgba(255, 255, 255, 0.95);
    }

    .glass-panel--solid {
      background: rgba(255, 255, 255, 0.98);
    }

    [data-theme="dark"] .glass-panel--default {
      background: rgba(20, 20, 20, 0.95);
    }

    [data-theme="dark"] .glass-panel--solid {
      background: rgba(10, 10, 10, 0.98);
    }
  }
</style>