---
import type { ImageMetadata } from 'astro';
import GlassCard from '@/components/ui/GlassCard.astro';
import Picture from '@/components/ui/Picture.astro';

export interface Props {
  title: string;
  summary: string;
  cover: ImageMetadata;
  coverAlt?: string;
  tech: string[];
  role: string;
  year: number;
  href: string;
  index: number;
  featured?: boolean;
  showTechStack?: boolean;
  showYear?: boolean;
}

const {
  title,
  summary,
  cover,
  coverAlt = title,
  tech,
  role,
  year,
  href,
  index,
  featured = false,
  showTechStack = true,
  showYear = true,
} = Astro.props;
---

<article class:list={['project', { 'project--featured': featured }]}>
  <GlassCard href={href} padding="none" radius="xl" class="project__card">
    <div class="project__visual">
      <Picture
        src={cover}
        alt={coverAlt}
        widths={[400, 800, 1200]}
        sizes={featured ? '(min-width: 900px) 60vw, 100vw' : '(min-width: 900px) 40vw, 100vw'}
        loading={index === 0 ? 'eager' : 'lazy'}
        fetchpriority={index === 0 ? 'high' : undefined}
        class="project__image"
      />
      <span class="project__number" aria-hidden="true">
        {String(index).padStart(2, '0')}
      </span>
      {featured && <span class="project__flag">Selected work</span>}
    </div>

    <div class="project__body">
      <div class="project__meta">
        {showYear && (
          <>
            <span>{year}</span>
            <span aria-hidden="true">/</span>
          </>
        )}
        <span>{role}</span>
      </div>

      <h2 class="project__title">{title}</h2>
      <p class="project__summary">{summary}</p>

      <div class:list={['project__footer', { 'project__footer--solo': !showTechStack }]}>
        {showTechStack && (
          <ul class="project__tech" aria-label="Technology stack">
            {tech.slice(0, featured ? 5 : 3).map((item) => <li>{item}</li>)}
          </ul>
        )}
        <span class="project__arrow" aria-hidden="true">↗</span>
      </div>
    </div>
  </GlassCard>
</article>

<style>
  .project,
  .project__card {
    height: 100%;
  }

  .project__card {
    display: grid;
    grid-template-rows: auto 1fr;
  }

  .project__visual {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background:
      linear-gradient(135deg, var(--color-accent-glass), transparent),
      var(--color-surface);
  }

  .project__visual :global(.project__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .project__card:hover .project__visual :global(.project__image) {
    transform: scale(1.035);
  }

  .project__number,
  .project__flag {
    position: absolute;
    z-index: 1;
    color: white;
    background: rgba(12, 14, 24, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.24);
  }

  .project__number {
    inset: var(--space-md) auto auto var(--space-md);
    display: grid;
    place-items: center;
    width: 2.75rem;
    aspect-ratio: 1;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
  }

  .project__flag {
    inset: var(--space-md) var(--space-md) auto auto;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .project__body {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
  }

  .project__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .project__title {
    margin-bottom: var(--space-sm);
    font-size: var(--text-2xl);
    line-height: 1.08;
  }

  .project__summary {
    flex: 1;
    margin-bottom: var(--space-xl);
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .project__footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .project__footer--solo {
    justify-content: flex-end;
  }

  .project__tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .project__tech li {
    margin: 0;
    padding: 0.2rem var(--space-sm);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-surface) 65%, transparent);
    font-size: var(--text-xs);
  }

  .project__arrow {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 2.5rem;
    aspect-ratio: 1;
    border-radius: 50%;
    color: var(--color-accent);
    background: var(--color-accent-glass);
    font-size: var(--text-lg);
    transition: transform var(--transition-base);
  }

  .project__card:hover .project__arrow {
    transform: rotate(45deg);
  }

  @media (min-width: 900px) {
    .project--featured {
      grid-column: 1 / -1;
    }

    .project--featured .project__card {
      grid-template-columns: minmax(0, 1.35fr) minmax(20rem, 0.8fr);
      grid-template-rows: none;
    }

    .project--featured .project__visual {
      aspect-ratio: auto;
      min-height: 31rem;
    }

    .project--featured .project__body {
      justify-content: end;
      padding: var(--space-2xl);
    }

    .project--featured .project__title {
      font-size: var(--text-4xl);
    }
  }

  @media (max-width: 640px) {
    .project__body {
      padding: var(--space-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project__visual :global(.project__image),
    .project__arrow {
      transition: none;
    }
  }
</style>
