---
import { getProjectBySlug } from '@/lib/db';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import Container from '@/components/ui/Container.astro';
import GlassCard from '@/components/ui/GlassCard.astro';
import Button from '@/components/ui/Button.astro';
import Picture from '@/components/ui/Picture.astro';
import ProjectGallery from '@/components/portfolio/ProjectGallery.astro';
import siteConfig from '@/site.config';
import { withBase } from '@/lib/url';

export const prerender = false;

type Props = any;

const slug = Array.isArray(Astro.params.slug) ? Astro.params.slug.join('/') : Astro.params.slug;
const project = (await getProjectBySlug(String(slug || ''))) || {};

function parseJson(value: any, fallback: any) {
  if (value === undefined || value === null) return fallback;
  if (typeof value === 'string') {
    try {
      return JSON.parse(value);
    } catch {
      return fallback;
    }
  }
  return value;
}

function renderMarkdown(md: string) {
  if (!md) return '';
  if (/<[^>]+>/m.test(md)) return md;
  var html = md;
  html = html.replace(/```([\s\S]*?)```/g, function (_m, code) { return '<pre><code>' + escapeHtml(code) + '</code></pre>'; });
  html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
  html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
  html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');
  html = html.replace(/\*\*(.*?)\*\*/gim, '<strong>$1</strong>');
  html = html.replace(/\*(.*?)\*/gim, '<em>$1</em>');
  html = html.replace(/`([^`]+)`/gim, '<code>$1</code>');
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/gim, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
  html = html.split(/\n\n+/).map(function (p) { return '<p>' + p.replace(/\n/g, '<br/>') + '</p>'; }).join('\n');
  return html;
}

function escapeHtml(str: string) {
  return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

const rawContent = project.content || project.description || '';
const contentHtml = renderMarkdown(rawContent);
const hasDetailedContent = Boolean(String(project.content || '').trim());
const hasLeadText = Boolean(String(project.description || '').trim()) && !hasDetailedContent;
const tech: string[] = typeof project.tech === 'string' ? parseJson(project.tech, []) : project.tech || [];
function normalizeImages(value: any) {
  if (!value) return [];
  if (Array.isArray(value)) return value.filter(Boolean);
  if (typeof value === 'string') {
    const parsed = parseJson(value, []);
    if (Array.isArray(parsed)) return parsed.filter(Boolean);
    if (parsed) return [parsed];
    return [];
  }
  if (typeof value === 'object') return [value];
  return [value];
}
const images = normalizeImages(project.images || project.gallery_images || project.gallery || []);
const links = typeof project.links === 'string' ? parseJson(project.links, {}) : project.links || {};
const description = project.description ?? project.summary;
const projectLinks = [
  links.live && {
    label: 'Visit live site',
    href: links.live,
    external: true,
  },
  links.github && {
    label: 'View source',
    href: links.github,
    external: true,
  },
  links.case && {
    label: 'Read case study',
    href: links.case,
    external: false,
  },
].filter((link): link is { label: string; href: string; external: boolean } => Boolean(link));
---

<BaseLayout
  title={project.title}
  description={description}
  ogImage={project.cover_image || project.cover}
>
  <Header />

  <main id="main" tabindex="-1">
    {project.title ? (
      <article>
        <header class="case-hero">
          <Container size="xl">
            <a class="case-hero__back" href={withBase('/work')}>← Kembali ke Portfolio</a>

            <div class="case-hero__content">
              <div class="case-hero__text">
                <p class="case-hero__kicker">
                  {project.role}{siteConfig.portfolio.showYear && project.year && ` / ${project.year}`}
                </p>
                <h1>{project.title}</h1>
                <p class="case-hero__summary">{project.summary}</p>

                {projectLinks.length > 0 && (
                  <div class="case-hero__actions" aria-label="Project links">
                    {projectLinks.map((link, index) => (
                      <Button
                        href={link.href}
                        variant={index === 0 ? 'solid' : 'outline'}
                        external={link.external}
                      >
                        {link.label}
                        <span aria-hidden="true">↗</span>
                      </Button>
                    ))}
                  </div>
                )}
              </div>

              <div class="case-hero__image">
                {(project.cover_image || project.cover) && (
                  <Picture
                    src={project.cover_image || project.cover}
                    alt={project.cover_alt ?? project.coverAlt ?? project.title}
                    widths={[600, 1200, 1586]}
                    sizes="100vw"
                    loading="eager"
                    fetchpriority="high"
                    class="case-cover"
                  />
                )}
              </div>
            </div>
          </Container>
        </header>

        <Container size="xl">
          <div class="case-overview">
            <GlassCard padding="lg" radius="xl" class="case-overview__card">
              <div class="case-overview__meta">
                {project.client && (
                  <div>
                    <dt>Client</dt>
                    <dd>{project.client}</dd>
                  </div>
                )}
                <div>
                  <dt>Role</dt>
                  <dd>{project.role}</dd>
                </div>
                {siteConfig.portfolio.showYear && (
                  <div>
                    <dt>Year</dt>
                    <dd>{project.year}</dd>
                  </div>
                )}
                {project.duration && (
                  <div>
                    <dt>Duration</dt>
                    <dd>{project.duration}</dd>
                  </div>
                )}
              </div>

              {siteConfig.portfolio.showTechStack && (
                <div class="case-facts__stack">
                  <p>Stack</p>
                  <ul>
                    {tech.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              )}
            </GlassCard>
          </div>
        </Container>

        <Container size="xl">
          <div class="case-content">
            <div class="case-content__panel">
              <p class="case-content__eyebrow">Project story</p>
              {hasLeadText && <p class="case-content__lead">{description}</p>}
              <div class="prose">
                {contentHtml ? <div set:html={contentHtml} /> : hasLeadText && <p>{description}</p>}
              </div>
            </div>
          </div>
        </Container>

        {(project.images || images.length > 0) && (
          <Container size="xl">
            <ProjectGallery images={project.images || images} title={project.title} />
          </Container>
        )}

        <Container size="xl">
          <nav class="case-next" aria-label="Portfolio navigation">
            <p>End of case file</p>
            <a href={withBase('/work')}>
              Explore all work
              <span aria-hidden="true">→</span>
            </a>
          </nav>
        </Container>
      </article>
    ) : (
      <section class="case-empty">
        <Container size="xl">
          <p class="case-empty__eyebrow">Portfolio</p>
          <h1>Detail portfolio belum tersedia</h1>
          <p>Portfolio yang Anda cari belum bisa dimuat. Coba kembali setelah data disimpan atau cek kembali tautan dari daftar portfolio.</p>
          <a class="case-empty__link" href={withBase('/work')}>← Kembali ke daftar portfolio</a>
        </Container>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>

<style>
  .case-hero {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 60%);
  }

  .case-hero__back {
    display: inline-flex;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .case-hero__back:hover {
    color: var(--color-accent);
  }

  .case-hero__content {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: clamp(var(--space-xl), 5vw, 4rem);
    align-items: center;
  }

  .case-hero__text {
    display: grid;
    gap: var(--space-lg);
  }

  .case-hero__kicker {
    margin: 0;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-hero h1 {
    max-width: 11ch;
    margin: 0;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.055em;
  }

  .case-hero__summary {
    max-width: 42rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-xl);
    line-height: 1.6;
  }

  .case-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .case-hero__image {
    overflow: hidden;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--glass-shadow);
    background: var(--color-surface);
  }

  .case-hero__image :global(.case-cover) {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .case-overview {
    margin-top: calc(-1 * var(--space-xl));
    position: relative;
    z-index: 2;
  }

  .case-overview__card {
    display: grid;
    gap: var(--space-lg);
    background: color-mix(in srgb, var(--glass-bg) 82%, transparent);
  }

  .case-overview__meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-lg);
  }

  .case-overview__meta > div {
    display: grid;
    gap: var(--space-xs);
  }

  .case-overview dt,
  .case-facts__stack > p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .case-overview dd {
    margin: 0;
    font-weight: 600;
  }

  .case-facts__stack {
    margin-top: var(--space-xs);
  }

  .case-facts__stack ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .case-facts__stack li {
    margin: 0;
    padding: 0.2rem var(--space-sm);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-surface) 65%, transparent);
    font-size: var(--text-xs);
  }

  .case-content {
    padding-top: var(--space-3xl);
  }

  .case-content__panel {
    max-width: 60rem;
    padding: clamp(var(--space-xl), 4vw, var(--space-2xl));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--glass-bg) 78%, transparent);
    box-shadow: var(--glass-shadow);
  }

  .case-content__eyebrow {
    margin: 0 0 var(--space-md);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-content__lead {
    margin: 0 0 var(--space-3xl);
    padding-left: var(--space-xl);
    border-left: 2px solid var(--color-accent);
    font-size: var(--text-xl);
    line-height: 1.7;
  }

  .prose :global(h2) {
    margin: var(--space-3xl) 0 var(--space-lg);
    font-size: var(--text-3xl);
    letter-spacing: -0.025em;
  }

  .prose :global(h3) {
    margin: var(--space-2xl) 0 var(--space-md);
    font-size: var(--text-xl);
  }

  .prose :global(p),
  .prose :global(li) {
    color: var(--color-text-muted);
    line-height: 1.85;
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
  }

  .prose :global(strong) {
    color: var(--color-text);
  }

  .prose :global(blockquote) {
    margin: var(--space-2xl) 0;
    padding: var(--space-lg) 0 var(--space-lg) var(--space-xl);
    border-left: 1px solid var(--glass-border);
    color: var(--color-text);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: var(--text-2xl);
    line-height: 1.45;
  }

  .prose :global(blockquote p) {
    margin: 0;
    color: inherit;
  }

  .case-next {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-top: calc(var(--space-3xl) * 1.5);
    padding-block: var(--space-xl);
    border-block: 1px solid var(--glass-border);
  }

  .case-next p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-next a {
    display: inline-flex;
    gap: var(--space-md);
    align-items: center;
    color: var(--color-text);
    font-size: var(--text-xl);
    font-weight: 700;
  }

  .case-next a span {
    color: var(--color-accent);
  }

  .case-empty {
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .case-empty__eyebrow {
    margin: 0 0 var(--space-md);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-empty h1 {
    margin: 0 0 var(--space-lg);
    font-size: clamp(2.2rem, 4vw, 3rem);
  }

  .case-empty p {
    max-width: 40rem;
    margin: 0 0 var(--space-xl);
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .case-empty__link {
    color: var(--color-accent);
    font-weight: 600;
  }

  @media (max-width: 860px) {
    .case-hero__content {
      grid-template-columns: 1fr;
    }

    .case-hero__image :global(.case-cover) {
      aspect-ratio: 16 / 10;
    }
  }

  @media (max-width: 640px) {
    .case-content__lead {
      padding-left: var(--space-lg);
      font-size: var(--text-lg);
    }

    .case-next {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
