---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import GlassPanel from '@/components/common/GlassPanel.astro';
import Container from '@/components/ui/Container.astro';
import { withBase } from '@/lib/url';
import { getAllPosts } from '@/lib/db';

function parseTags(tags: string | string[] | null | undefined) {
  if (!tags) return [];

  if (Array.isArray(tags)) {
    return tags.map((tag) => String(tag).trim()).filter(Boolean);
  }

  const raw = String(tags).trim();
  if (!raw) return [];

  try {
    const parsed = JSON.parse(raw);
    if (Array.isArray(parsed)) {
      return parsed.map((tag) => String(tag).trim()).filter(Boolean);
    }
    if (typeof parsed === 'string') {
      return [parsed.trim()].filter(Boolean);
    }
  } catch {
    // ignore and fall back to manual parsing below
  }

  const quotedMatches = raw.match(/['"]([^'"]+)['"]/g) || [];
  if (quotedMatches.length > 0) {
    return quotedMatches.map((match) => match.replace(/^['"]|['"]$/g, '').trim()).filter(Boolean);
  }

  return raw
    .split(/[,;]+/)
    .map((t) => t.trim())
    .filter(Boolean);
}

function tagSlug(tag: string) {
  return tag
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

function collectTagsFromPosts(posts: any[]) {
  const bySlug = new Map<string, { tag: string; count: number }>();
  for (const post of posts) {
    const tags = parseTags(post.tags);
    const seen = new Set<string>();
    for (const raw of tags) {
      const slug = tagSlug(raw);
      if (!slug || seen.has(slug)) continue;
      seen.add(slug);
      const existing = bySlug.get(slug);
      if (existing) existing.count += 1;
      else bySlug.set(slug, { tag: raw, count: 1 });
    }
  }
  return [...bySlug.entries()]
    .map(([slug, { tag, count }]) => ({ tag, slug, count }))
    .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag));
}

let tags: any[] = [];
try {
  const posts = await getAllPosts();
  tags = collectTagsFromPosts(posts);
} catch (error) {
  console.error('Error loading tags:', error);
}
const maxCount = tags.reduce((m, t) => Math.max(m, t.count), 1);
---

<BaseLayout title="Tag" description="Jelajahi artikel SeminarKit berdasarkan topik dan jenis acara.">
  <Header />

  <main id="main" tabindex="-1" class="main-content">
    <section class="section">
      <Container size="md">
        <header class="tags-header">
          <h1 class="tags-title">Tag</h1>
          <p class="tags-subtitle">Temukan artikel berdasarkan topik seminar dan acara.</p>
        </header>

        {
          tags.length === 0 ? (
            <GlassPanel variant="default" padding="xl" className="empty">
              <p>Belum ada tag saat ini.</p>
            </GlassPanel>
          ) : (
            <GlassPanel variant="solid" padding="xl">
              <ul class="tag-cloud">
                {tags.map(({ tag, slug, count }) => (
                  <li>
                    <a
                      class="tag-cloud__item"
                      href={withBase(`/tags/${slug}`)}
                      style={`--weight: ${0.85 + (count / maxCount) * 0.6}`}
                    >
                      <span class="tag-cloud__hash">#</span>
                      {tag}
                      <span class="tag-cloud__count">{count}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </GlassPanel>
          )
        }
      </Container>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main-content {
    min-height: 100vh;
    padding-top: var(--space-2xl);
  }

  .section {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .tags-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .tags-title {
    font-size: var(--text-4xl);
    font-weight: 800;
  }

  .tags-subtitle {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .tag-cloud {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .tag-cloud__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-full);
    border: 1px solid var(--glass-border);
    color: var(--color-text);
    text-decoration: none;
    font-size: calc(var(--text-base) * var(--weight, 1));
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .tag-cloud__item:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-glass);
  }

  .tag-cloud__item:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .tag-cloud__hash {
    color: var(--color-accent);
  }

  .tag-cloud__count {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--glass-bg);
    border-radius: var(--radius-full);
    padding: 0 var(--space-xs);
    min-width: 1.4em;
    text-align: center;
  }

  .empty {
    text-align: center;
  }
</style>
