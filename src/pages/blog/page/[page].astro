---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import Container from '@/components/ui/Container.astro';
import PostGrid from '@/components/blog/PostGrid.astro';
import Pagination from '@/components/blog/Pagination.astro';
import { getAllPosts } from '@/lib/db';
import siteConfig from '@/site.config';

function mapRowsToPosts(rows: any[]) {
  return rows.map((post) => ({
    id: post.id.toString(),
    data: {
      title: post.title,
      description: post.excerpt,
      pubDate: new Date(post.published_at),
      heroImage: post.cover_image || undefined,
      heroImageAlt: post.title,
      tags: parseTags(post.tags),
      featured: post.is_featured === 1,
    },
    body: post.content,
    slug: post.slug,
  }));
}

function parseTags(tags: string | null | undefined) {
  if (!tags) return [];
  try {
    const parsed = JSON.parse(tags);
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return String(tags)
      .split(',')
      .map((t) => t.trim())
      .filter(Boolean);
  }
}

export const getStaticPaths = (async () => {
  const posts = mapRowsToPosts(await getAllPosts());
  const perPage = siteConfig.blog.postsPerPage;
  const totalPages = Math.max(1, Math.ceil(posts.length / perPage));

  const paths = [];
  for (let page = 2; page <= totalPages; page++) {
    paths.push({
      params: { page: String(page) },
      props: {
        posts: posts.slice((page - 1) * perPage, page * perPage),
        currentPage: page,
        totalPages,
      },
    });
  }
  return paths;
}) satisfies GetStaticPaths;

interface Props {
  posts: any[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;
---

<BaseLayout
  title={`Blog — Page ${currentPage}`}
  description="Semua panduan, checklist, dan cerita SeminarKit untuk acara seminar profesional."
>
  <Header />

  <main id="main" tabindex="-1" class="main-content">
    <section class="section">
      <Container>
        <h2 class="section-title">Semua Artikel</h2>
        <PostGrid posts={posts} />
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          basePath="/blog"
        />
      </Container>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main-content {
    min-height: 100vh;
    padding-top: var(--space-2xl);
  }

  .section {
    padding: var(--space-3xl) 0;
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-2xl);
    text-align: center;
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: var(--text-2xl);
    }
  }
</style>
