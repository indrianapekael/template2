---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import GlassPanel from '@/components/common/GlassPanel.astro';
import GlassCard from '@/components/ui/GlassCard.astro';
import Tag from '@/components/ui/Tag.astro';
import Picture from '@/components/ui/Picture.astro';
import { withBase } from '@/lib/url';
import { getPost, getPostBySlug } from '@/lib/db';
import siteConfig from '@/site.config';
import MarkdownIt from 'markdown-it';

// Server-side rendering
export const prerender = false;

const rawSlug = Astro.params.slug;
const slug = Array.isArray(rawSlug) ? rawSlug.join('/') : rawSlug;
let post: any = null;

try {
  if (!slug) return Astro.redirect('/blog');

  const maybeId = Number(slug);
  if (!Number.isNaN(maybeId) && String(maybeId) === slug) {
    post = await getPost(maybeId);
  }

  if (!post) {
    post = await getPostBySlug(slug as string);
  }

  if (!post) return Astro.redirect('/blog');
} catch (error) {
  console.error('Error loading post:', error);
  return Astro.redirect('/blog');
}

// Calculate reading time (rough estimate based on word count)
const wordCount = String(post?.content ?? '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.ceil(wordCount / 200);

// Format dates
const dateOpts = { year: 'numeric', month: 'long', day: 'numeric' } as const;
const pubDate = new Date(post.published_at);
const formattedDate = pubDate.toLocaleDateString('en-US', dateOpts);

// Parse tags
let tags: string[] = [];
if (post.tags) {
  try {
    tags = JSON.parse(post.tags);
  } catch {
    tags = post.tags.split(',').map((t: string) => t.trim()).filter(Boolean);
  }
}

// Inject IDs into headings so TOC links work and collect TOC
function slugify(text: string) {
  return String(text)
    .toLowerCase()
    .trim()
    .replace(/<[^>]+>/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

// Render markdown to HTML if content looks like markdown
let contentHtml = post.content || '';
try {
  const md = new MarkdownIt({ html: true, linkify: true });
  contentHtml = md.render(String(post.content || ''));
} catch (e) {
  // fall back to raw content
  contentHtml = String(post.content || '');
}
const toc: { id: string; text: string }[] = [];
contentHtml = contentHtml.replace(/<(h2|h3)([^>]*)>(.*?)<\/\1>/gi, (_m: string, tag: string, attrs: string, inner: string) => {
  const id = slugify(inner);
  toc.push({ id, text: inner.replace(/<[^>]+>/g, '') });
  return `<${tag}${attrs} id="${id}">${inner}</${tag}>`;
});

// Social sharing URLs
const tweetUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(
  post.title
)}&url=${encodeURIComponent(Astro.url.href)}`;
const linkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(
  Astro.url.href
)}`;
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  ogImage={post.cover_image}
  article={{
    publishedTime: pubDate.toISOString(),
    author: '',
    tags: tags,
  }}
>
  <Header />

  <main id="main" tabindex="-1" class="main-content">
    <article class="blog-post">
      <div class="container">
        <GlassPanel variant="solid" padding="xl" className="post-header">
          <a href={withBase('/blog')} class="post-back">← Kembali ke blog</a>
          <h1 class="post-title">{post.title}</h1>

          <div class="post-meta">
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            {
              siteConfig.blog.showReadingTime && readingTime > 0 && (
                <>
                  <span class="separator" aria-hidden="true">·</span>
                  <span>{readingTime} min read</span>
                </>
              )
            }
          </div>

          {
            tags.length > 0 && (
              <div class="post-tags">
                {tags.map((tag: string) => (
                  <Tag name={tag} />
                ))}
              </div>
            )
          }
        </GlassPanel>

        {
          post.cover_image && (
            <div class="post-hero">
              <Picture
                src={post.cover_image}
                alt={post.title || 'Gambar artikel'}
                width={1200}
                height={600}
                sizes="100vw"
                loading="eager"
                class="post-hero__img"
              />
            </div>
          )
        }

        {
          !post.cover_image && (
            <div class="post-hero">
              <Picture
                src="/src/assets/images/product/paket-terorganisir.webp"
                alt={post.title || 'Gambar artikel'}
                width={1200}
                height={600}
                sizes="100vw"
                loading="eager"
                class="post-hero__img"
              />
            </div>
          )
        }

        <div class="post-content">
          <div class="content-wrapper">
            <div class="prose" set:html={contentHtml} />
            <div class="post-share">
              <GlassCard>
                <h3 class="sidebar-title">Bagikan artikel ini</h3>
                <div class="social-links">
                  <a href={tweetUrl} target="_blank" rel="noopener noreferrer" class="social-link">Bagikan ke X</a>
                  <a href={linkedInUrl} target="_blank" rel="noopener noreferrer" class="social-link">Bagikan ke LinkedIn</a>
                </div>
              </GlassCard>
            </div>
          </div>

          <aside class="post-sidebar">
            <GlassCard>
              <h3 class="sidebar-title">Di halaman ini</h3>
              {toc.length === 0 ? (
                <p class="sidebar-empty">Tidak ada heading</p>
              ) : (
                <ul class="toc-list">
                  {toc.map((t) => (
                    <li><a href={'#' + t.id}>{t.text}</a></li>
                  ))}
                </ul>
              )}
            </GlassCard>
          </aside>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<script type="module">
  // Smooth scrolling and active TOC highlighting
  document.addEventListener('DOMContentLoaded', () => {
    const tocList = document.querySelector('.toc-list');
    if (!tocList) return;

    const links = Array.from(tocList.querySelectorAll('a'));
    if (links.length === 0) return;

    // click handler: smooth scroll
    links.forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const href = a.getAttribute('href') || '';
        const id = href.replace(/^#/, '');
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          try { history.replaceState(null, '', '#' + id); } catch (err) {}
        }
      });
    });

    // observe headings and toggle active class on links
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const id = entry.target.id;
        const link = tocList.querySelector(`a[href="#${id}"]`);
        if (!link) return;
        if (entry.isIntersecting) link.classList.add('active');
        else link.classList.remove('active');
      });
    }, { root: null, rootMargin: '0px 0px -60% 0px', threshold: 0.1 });

    const headings = Array.from(document.querySelectorAll('.prose h2, .prose h3'));
    headings.forEach((h) => { if (h.id) observer.observe(h); });
  });
</script>

<style>
  .toc-list a.active {
    color: var(--color-accent);
    font-weight: 700;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-list li { margin: 0.4rem 0; }
</style>

<style>
  .main-content {
    min-height: 100vh;
    padding-bottom: var(--space-3xl);
  }

  .blog-post {
    padding-top: var(--space-2xl);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .post-header {
    margin-bottom: var(--space-3xl);
    text-align: center;
  }

  .post-hero {
    max-width: 900px;
    margin: 0 auto var(--space-3xl);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  }

  .post-hero__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .post-back {
    display: inline-block;
    margin-bottom: var(--space-lg);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .post-back:hover {
    color: rgba(255, 255, 255, 1);
  }

  .post-title {
    font-size: var(--text-5xl);
    font-weight: 800;
    margin-bottom: var(--space-lg);
  }

  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-md);
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.95rem;
  }

  .separator {
    opacity: 0.3;
  }

  .post-tags {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  .post-image {
    margin-bottom: var(--space-3xl);
    border-radius: 12px;
    overflow: hidden;
  }

  .post-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-content {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-xl);
  }

  .prose {
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.9);
  }

  .post-share {
    margin-top: var(--space-2xl);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .toc-list a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .sidebar-empty {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .prose :global(h2) {
    font-size: 2rem;
    font-weight: 700;
    margin: var(--space-2xl) 0 var(--space-lg);
  }

  .prose :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    margin: var(--space-xl) 0 var(--space-md);
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
  }

  .prose :global(a) {
    color: #60a5fa;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .prose :global(a:hover) {
    text-decoration: underline;
  }

  .prose :global(code) {
    background: rgba(255, 255, 255, 0.05);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'Monaco', 'Courier New', monospace;
    font-size: 0.9em;
    color: #fca5a5;
  }

  .prose :global(pre) {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--space-lg);
    border-radius: 8px;
    overflow-x: auto;
    margin: var(--space-lg) 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }

  .prose :global(blockquote) {
    border-left: 4px solid #60a5fa;
    padding-left: var(--space-lg);
    margin: var(--space-lg) 0;
    font-style: italic;
    color: rgba(255, 255, 255, 0.7);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: var(--space-lg) 0;
    padding-left: var(--space-xl);
  }

  .prose :global(li) {
    margin-bottom: var(--space-md);
  }

  .post-sidebar {
    position: sticky;
    top: var(--space-xl);
    height: fit-content;
  }

  .sidebar-title {
    margin-bottom: var(--space-lg);
    font-weight: 600;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .social-link {
    display: inline-block;
    padding: var(--space-md) var(--space-lg);
    background: rgba(96, 165, 250, 0.1);
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 8px;
    color: #93c5fd;
    text-decoration: none;
    text-align: center;
    transition: all var(--transition-base);
  }

  .social-link:hover {
    background: rgba(96, 165, 250, 0.2);
    border-color: rgba(96, 165, 250, 0.5);
  }

  @media (max-width: 768px) {
    .post-content {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      position: static;
      top: auto;
    }

    .post-title {
      font-size: var(--text-3xl);
    }
  }
</style>
                ))}
              </div>
            )
          }
        </GlassPanel>

        {
          post.data.heroImage && (
            <div class="post-hero-image">
              <Picture
                src={post.data.heroImage}
                alt={post.data.heroImageAlt ?? post.data.title}
                widths={[600, 1200, 1600]}
                sizes="(min-width: 1024px) 720px, 100vw"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          )
        }

        <div class={`post-body`}>
          <GlassPanel variant="solid" padding="xl" className="post-content">
            <div class="prose">
              <div set:html={post.content} />
            </div>
          </GlassPanel>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main-content {
    min-height: 100vh;
  }

  .blog-post {
    padding: var(--space-2xl) 0;
  }

  .blog-post .container {
    max-width: var(--container-5xl);
    margin-inline: auto;
    padding-inline: var(--space-lg);
  }

  .post-back {
    display: inline-block;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-md);
    transition: color var(--transition-fast);
  }
  .post-back:hover {
    color: var(--color-accent);
  }

  .post-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .post-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: var(--space-lg);
    background: linear-gradient(135deg, var(--color-text), var(--color-accent));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .separator {
    opacity: 0.5;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }

  .post-hero-image {
    margin-bottom: var(--space-2xl);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--glass-shadow);
  }

  .post-hero-image :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Body + optional TOC sidebar */
  .post-body {
    display: grid;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .post-body--with-toc {
    grid-template-columns: minmax(0, 1fr) 16rem;
  }

  .post-toc__inner {
    position: sticky;
    top: calc(var(--space-3xl) + var(--space-md));
  }

  .prose {
    font-size: var(--text-base);
    line-height: 1.8;
  }

  /* Offset anchored headings from the sticky header */
  .prose :global(:is(h2, h3, h4)) {
    scroll-margin-top: var(--space-3xl);
  }

  .post-footer {
    margin-top: var(--space-2xl);
  }

  .share-title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .share-buttons {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .share-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    font-weight: 500;
  }

  .share-button:hover {
    color: var(--color-accent);
  }

  /* Prev / next */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
  }

  .post-nav__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .post-nav__card--next {
    text-align: right;
  }

  .post-nav__dir {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 600;
  }

  .post-nav__title {
    font-weight: 600;
    line-height: 1.3;
  }

  @media (max-width: 900px) {
    .post-body--with-toc {
      grid-template-columns: 1fr;
    }
    .post-toc {
      order: -1;
    }
    .post-toc__inner {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: var(--text-3xl);
    }
    .post-meta {
      font-size: var(--text-xs);
    }
    .blog-post {
      padding: var(--space-lg) 0;
    }
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav__card--next {
      text-align: left;
    }
  }
</style>
