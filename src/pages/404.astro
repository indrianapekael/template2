---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import GlassPanel from '@/components/common/GlassPanel.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import { withBase } from '@/lib/url';
---

<BaseLayout
  title="Page not found"
  description="The page you were looking for doesn't exist or has moved."
  noIndex={true}
>
  <Header />

  <main id="main" tabindex="-1" class="main-content">
    <section class="section">
      <Container size="md">
        <GlassPanel variant="solid" padding="xl" className="notfound">
          <p class="notfound__code" aria-hidden="true">404</p>
          <h1 class="notfound__title">Page not found</h1>
          <p class="notfound__text">
            The page you were looking for doesn't exist or may have moved.
            Let's get you back on track.
          </p>
          <div class="notfound__actions">
            <Button href={withBase('/')} variant="solid">Back to home</Button>
            <Button href={withBase('/blog')} variant="glass">Browse the blog</Button>
          </div>
        </GlassPanel>
      </Container>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main-content {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .notfound {
    text-align: center;
  }

  .notfound__code {
    font-size: var(--text-5xl);
    font-weight: 800;
    line-height: 1;
    margin-bottom: var(--space-sm);
    color: var(--color-accent-text);
  }

  .notfound__title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
  }

  .notfound__text {
    color: var(--color-text-muted);
    max-width: 42ch;
    margin: 0 auto var(--space-xl);
  }

  .notfound__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
