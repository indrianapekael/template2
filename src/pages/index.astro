---
import BaseLayout from '@/layouts/BaseLayout.astro';
import siteConfig from '@/site.config';
import { withBase } from '@/lib/url';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import GlassCard from '@/components/ui/GlassCard.astro';
import Section from '@/components/ui/Section.astro';

const showcases = [
  {
    index: '01',
    type: 'Editorial',
    title: 'Ideas with a place to unfold.',
    description: 'A reading-first blog system with strong rhythm, calm metadata, and focused article pages.',
    href: '/blog',
    cta: 'Enter the journal',
    className: 'showcase--journal',
  },
  {
    index: '02',
    type: 'Selected work',
    title: 'Case studies that show the thinking.',
    description: 'A portfolio structure for outcomes, process, roles, and the details behind the final frame.',
    href: '/work',
    cta: 'Browse selected work',
    className: 'showcase--work',
  },
  {
    index: '03',
    type: 'Campaign',
    title: 'A landing page built to persuade quietly.',
    description: 'Data-driven product storytelling with benefits, pricing, social proof, FAQ, and external calls to action.',
    href: '/landing',
    cta: 'Open the live demo',
    className: 'showcase--landing',
  },
];
---

<BaseLayout
  title={`${siteConfig.name} — One system, three ways to publish`}
  description="A production-ready Astro theme for editorial blogs, portfolios, and focused landing pages."
>
  <Header />

  <main id="main" tabindex="-1">
    <section class="home-hero">
      <Container size="xl">
        <div class="home-hero__meta">
          <span>Astro 7 theme system</span>
          <span>Edition 2026</span>
        </div>
        <h1>
          One atmosphere.<br />
          <span>Three ways to publish.</span>
        </h1>
        <div class="home-hero__footer">
          <p>
            Astro Haze is a modular showcase for thoughtful writing, selected work, and
            focused campaigns—fast by default and expressive where it counts.
          </p>
          <div class="home-hero__actions">
            <Button href="#showcase" variant="solid" size="lg">Explore the system</Button>
            {
              siteConfig.social.github && (
                <Button href={siteConfig.social.github} external variant="outline" size="lg">
                  View source <span aria-hidden="true">↗</span>
                </Button>
              )
            }
          </div>
        </div>
        <div class="home-hero__orbit" aria-hidden="true">
          <span>Write</span><span>Show</span><span>Launch</span>
        </div>
      </Container>
    </section>

    <Section
      id="showcase"
      eyebrow="Choose your canvas"
      title="Three complete starting points."
      subtitle="Each preview shares the same accessible foundation while keeping its own pace, hierarchy, and purpose."
      align="left"
      container="xl"
    >
      <div class="showcase-list">
        {
          showcases.map((item) => (
            <article class:list={['showcase', item.className]}>
              <div class="showcase__copy">
                <div class="showcase__label">
                  <span>{item.index}</span>
                  <Badge variant="accent" size="sm">{item.type}</Badge>
                </div>
                <h2>{item.title}</h2>
                <p>{item.description}</p>
                <a href={withBase(item.href)}>{item.cta}<span aria-hidden="true"> →</span></a>
              </div>
              <GlassCard padding="none" radius="xl" class="showcase__preview">
                {item.index === '01' && (
                  <div class="preview preview--journal">
                    <div class="preview__nav"><i></i><span>FIELD / NOTES</span><small>ISSUE 04</small></div>
                    <div class="preview__editorial">
                      <span>Design practice</span>
                      <h3>Making space for the useful.</h3>
                      <p>On restraint, rhythm, and the objects that earn a permanent place.</p>
                    </div>
                    <div class="preview__lines"><i></i><i></i><i></i></div>
                  </div>
                )}
                {item.index === '02' && (
                  <div class="preview preview--work">
                    <div class="preview__poster">
                      <span>H / 02</span>
                      <div class="preview__shape"></div>
                      <strong>Common<br />Ground</strong>
                    </div>
                    <div class="preview__caption"><span>Brand system</span><span>2026 ↗</span></div>
                  </div>
                )}
                {item.index === '03' && (
                  <div class="preview preview--landing">
                    <span class="preview__edition">EDITION 01</span>
                    <div class="preview__object" aria-hidden="true"></div>
                    <h3>Objects for slower,<br />better days.</h3>
                    <span class="preview__button">VIEW COLLECTION ↗</span>
                  </div>
                )}
              </GlassCard>
            </article>
          ))
        }
      </div>
    </Section>

    <section class="system-note">
      <Container size="xl">
        <div>
          <span class="system-note__index">04 / FOUNDATION</span>
          <h2>Built for the work after launch.</h2>
        </div>
        <div class="system-note__grid">
          <p><strong>Content Layer</strong><span>Typed collections for entries, projects, and campaign data.</span></p>
          <p><strong>Responsive media</strong><span>AVIF-first local imagery with practical fallbacks.</span></p>
          <p><strong>Accessible glass</strong><span>Focused effects, robust contrast, and transparency preferences.</span></p>
          <p><strong>Minimal runtime</strong><span>Server-rendered pages and native interactions wherever possible.</span></p>
        </div>
      </Container>
    </section>

    <section class="home-cta">
      <Container size="xl">
        <p>Start with a structure. Make the atmosphere yours.</p>
        <h2>Pick a page and begin.</h2>
        <div>
          <Button href={withBase('/blog')} variant="outline" size="lg">Read</Button>
          <Button href={withBase('/work')} variant="outline" size="lg">Show</Button>
          <Button href={withBase('/landing')} variant="solid" size="lg">Launch</Button>
        </div>
      </Container>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    overflow: clip;
  }

  .home-hero {
    position: relative;
    min-height: min(54rem, calc(100vh - 5rem));
    display: grid;
    align-items: center;
    padding-block: clamp(5rem, 12vw, 10rem);
  }

  .home-hero__meta {
    display: flex;
    justify-content: space-between;
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--glass-border);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .home-hero h1 {
    position: relative;
    z-index: 1;
    margin-block: clamp(3rem, 8vw, 6rem);
    font-size: clamp(3.8rem, 10vw, 9.5rem);
    line-height: 0.84;
    letter-spacing: -0.075em;
  }

  .home-hero h1 span {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .home-hero__footer {
    display: grid;
    grid-template-columns: minmax(18rem, 1fr) auto;
    align-items: end;
    gap: var(--space-2xl);
  }

  .home-hero__footer > p {
    max-width: 40rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .home-hero__orbit {
    position: absolute;
    top: 26%;
    right: -4rem;
    width: 24rem;
    height: 24rem;
    border: 1px solid var(--glass-border);
    border-radius: 50%;
    animation: slow-spin 24s linear infinite;
    opacity: 0.55;
  }

  .home-hero__orbit::before {
    content: '';
    position: absolute;
    inset: 20%;
    border: 1px solid var(--glass-border);
    border-radius: 50%;
  }

  .home-hero__orbit span {
    position: absolute;
    padding: 0.25rem 0.6rem;
    background: var(--color-bg);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .home-hero__orbit span:nth-child(1) { top: 3rem; left: 1rem; }
  .home-hero__orbit span:nth-child(2) { top: 50%; right: -1rem; }
  .home-hero__orbit span:nth-child(3) { bottom: 1rem; left: 5rem; }

  .showcase-list {
    display: grid;
    gap: clamp(5rem, 12vw, 10rem);
  }

  .showcase {
    display: grid;
    grid-template-columns: minmax(17rem, 0.7fr) minmax(24rem, 1.3fr);
    align-items: center;
    gap: clamp(2.5rem, 8vw, 8rem);
  }

  .showcase:nth-child(even) .showcase__copy {
    order: 2;
  }

  .showcase__label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2xl);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .showcase__copy h2 {
    font-size: clamp(2.5rem, 5vw, 4.75rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .showcase__copy > p {
    margin-block: var(--space-lg) var(--space-xl);
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }

  .showcase__copy > a {
    display: inline-flex;
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent);
  }

  .showcase__preview {
    min-height: 34rem;
  }

  .preview {
    min-height: 34rem;
  }

  .preview--journal {
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: var(--space-xl);
    background: color-mix(in srgb, var(--color-surface) 90%, transparent);
  }

  .preview__nav,
  .preview__caption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .preview__nav i {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .preview__nav small {
    color: var(--color-text-muted);
  }

  .preview__editorial {
    align-self: center;
    max-width: 31rem;
    padding-left: clamp(1rem, 6vw, 5rem);
  }

  .preview__editorial > span,
  .preview__edition {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .preview__editorial h3 {
    margin-block: var(--space-md);
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .preview__editorial p {
    color: var(--color-text-muted);
  }

  .preview__lines {
    display: grid;
    gap: var(--space-sm);
  }

  .preview__lines i {
    height: 1px;
    background: var(--glass-border);
  }

  .preview__lines i:nth-child(2) { width: 74%; }
  .preview__lines i:nth-child(3) { width: 42%; }

  .preview--work {
    display: grid;
    grid-template-rows: 1fr auto;
    padding: var(--space-md);
    background: color-mix(in srgb, var(--aurora-2) 12%, var(--color-surface));
  }

  .preview__poster {
    position: relative;
    overflow: hidden;
    min-height: 29rem;
    padding: var(--space-xl);
    border-radius: calc(var(--radius-xl) - var(--space-sm));
    background: hsl(225 24% 12%);
    color: hsl(40 30% 94%);
  }

  .preview__poster > span {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .preview__poster strong {
    position: absolute;
    left: var(--space-xl);
    bottom: var(--space-xl);
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 0.78;
    letter-spacing: -0.07em;
    z-index: 1;
  }

  .preview__shape {
    position: absolute;
    width: 19rem;
    height: 19rem;
    top: 8%;
    right: 5%;
    border-radius: 48% 52% 64% 36% / 35% 45% 55% 65%;
    background: linear-gradient(145deg, var(--aurora-2), var(--aurora-1));
    filter: saturate(0.65);
    transform: rotate(24deg);
  }

  .preview__caption {
    padding: var(--space-md) var(--space-sm) var(--space-xs);
  }

  .preview--landing {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-xl);
    background:
      radial-gradient(circle at 75% 32%, color-mix(in srgb, var(--aurora-4) 26%, transparent), transparent 36%),
      color-mix(in srgb, var(--color-surface) 92%, transparent);
  }

  .preview--landing h3 {
    position: relative;
    z-index: 1;
    margin: auto 0 var(--space-xl);
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    line-height: 0.87;
    letter-spacing: -0.065em;
  }

  .preview__button {
    align-self: flex-start;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-full);
    background: var(--color-text);
    color: var(--color-bg);
    font-size: var(--text-xs);
    font-weight: 800;
  }

  .preview__object {
    position: absolute;
    top: 15%;
    right: 8%;
    width: 11rem;
    height: 17rem;
    border-radius: 5.5rem 5.5rem 2rem 2rem;
    background: linear-gradient(135deg, hsl(35 45% 78%), hsl(20 24% 46%));
    box-shadow: 0 3rem 5rem rgba(0, 0, 0, 0.2);
    transform: rotate(10deg);
  }

  .system-note {
    padding-block: clamp(6rem, 14vw, 12rem);
  }

  .system-note :global(.container) {
    display: grid;
    grid-template-columns: minmax(18rem, 0.8fr) minmax(20rem, 1.2fr);
    gap: clamp(3rem, 9vw, 9rem);
  }

  .system-note__index {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .system-note h2 {
    max-width: 10ch;
    margin-top: var(--space-lg);
    font-size: clamp(2.7rem, 5vw, 5rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .system-note__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    align-content: start;
  }

  .system-note__grid p {
    display: grid;
    gap: var(--space-sm);
    margin: 0;
    padding: var(--space-xl);
    border-top: 1px solid var(--glass-border);
  }

  .system-note__grid p:nth-child(odd) {
    border-right: 1px solid var(--glass-border);
  }

  .system-note__grid span {
    color: var(--color-text-muted);
  }

  .home-cta {
    padding-block: clamp(5rem, 12vw, 10rem);
    text-align: center;
  }

  .home-cta p {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .home-cta h2 {
    margin-block: var(--space-lg) var(--space-2xl);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.065em;
  }

  .home-cta div {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  @keyframes slow-spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 820px) {
    .home-hero__footer,
    .showcase,
    .system-note :global(.container) {
      grid-template-columns: 1fr;
    }

    .showcase:nth-child(even) .showcase__copy {
      order: initial;
    }

    .home-hero__orbit {
      opacity: 0.25;
    }
  }

  @media (max-width: 560px) {
    .home-hero__meta {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .showcase__preview,
    .preview {
      min-height: 29rem;
    }

    .system-note__grid {
      grid-template-columns: 1fr;
    }

    .system-note__grid p:nth-child(odd) {
      border-right: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero__orbit {
      animation: none;
    }
  }

  @media (prefers-reduced-transparency: reduce) {
    .preview--journal,
    .preview--landing {
      background: var(--color-surface);
    }
  }
</style>
