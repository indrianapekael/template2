        return 'contentList';
      }

      function getListEmptyMessage() {
        return '📭 Belum ada ' + getContentLabel(contentType) + '. <a href="#" onclick="document.querySelector(\'[data-tab="create"]\').click(); return false;" style="color: #60a5fa; text-decoration: underline;">Buat yang pertama!</a>';
      }

      function getContentApiPath(id) {
        return apiMap[contentType] + (id ? '/' + id : '');
      }

      function renderDashboardLatest(posts, projects, products) {
        function formatLatest(items, formatter, emptyLabel) {
          if (!Array.isArray(items) || items.length === 0) {
            return '<li class="dashboard-latest-empty">' + escapeHtml(emptyLabel) + '</li>';
          }

          return items.slice(0, 3).map(function (item) {
            var title = item.title || item.name || 'Tanpa judul';
            var dateLabel = formatter(item);
            return '<li><div><strong>' + escapeHtml(title) + '</strong>' + (dateLabel ? '<small>' + escapeHtml(dateLabel) + '</small>' : '') + '</div></li>';
          }).join('');
        }

        var latestPosts = document.getElementById('latestPosts');
        var latestProjects = document.getElementById('latestProjects');
        var latestProducts = document.getElementById('latestProducts');

        if (latestPosts) latestPosts.innerHTML = formatLatest(posts, function (item) {
          return item.published_at ? (new Date(item.published_at)).toLocaleDateString('id-ID') : 'Tanggal tidak tersedia';
        }, 'Tidak ada artikel');

        if (latestProjects) latestProjects.innerHTML = formatLatest(projects, function (item) {
          return item.year ? 'Tahun ' + item.year : item.published_at ? (new Date(item.published_at)).toLocaleDateString('id-ID') : 'Tanggal tidak tersedia';
        }, 'Tidak ada portfolio');

        if (latestProducts) latestProducts.innerHTML = formatLatest(products, function (item) {
          return item.published_at ? (new Date(item.published_at)).toLocaleDateString('id-ID') : item.price ? item.price : 'Tanggal tidak tersedia';
        }, 'Tidak ada produk');
      }

      function updateTypeSections(type) {
        document.querySelectorAll('.type-section').forEach(function (section) {
          section.style.display = section.classList.contains(type + '-only') ? 'block' : 'none';
        });
