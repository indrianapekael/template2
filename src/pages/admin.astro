        contentType = type;
        document.querySelectorAll('.type-btn').forEach(function (btn) {
          var active = btn.dataset.type === type;
          btn.classList.toggle('active', active);
          btn.setAttribute('aria-selected', String(active));
        });
        updateTypeSections(type);
        var pageActions = document.querySelector('.page-actions');
        var listTabBtn = document.querySelector('[data-tab="list"]');
        var createTabBtn = document.querySelector('[data-tab="create"]');
        var dashboardTab = document.getElementById('dashboard-tab');
        var listTab = document.getElementById('list-tab');
        var createTab = document.getElementById('create-tab');

        if (type === 'dashboard') {
          if (pageActions) pageActions.style.display = 'none';
          if (dashboardTab) dashboardTab.classList.add('active');
          if (listTab) listTab.classList.remove('active');
          if (createTab) createTab.classList.remove('active');
          if (listTabBtn) listTabBtn.classList.remove('active');
          if (createTabBtn) createTabBtn.classList.remove('active');
          loadDashboardStats();
          return;
        }

        if (pageActions) pageActions.style.display = 'inline-flex';
        if (dashboardTab) dashboardTab.classList.remove('active');
        if (createTab) createTab.classList.remove('active');
        if (listTab) listTab.classList.add('active');
        if (listTabBtn) listTabBtn.classList.add('active');
        if (createTabBtn) createTabBtn.classList.remove('active');

        if (document.getElementById('contentId')) document.getElementById('contentId').value = '';
        var form = document.getElementById('contentForm');
        if (form) form.reset();
        if (imagePreview) imagePreview.style.display = 'none';
        if (coverImageInput) coverImageInput.value = '';
        var titleEl = document.getElementById('title');
        var titleLabel = document.getElementById('titleLabel');
        var excerptEl = document.getElementById('excerpt');
        var excerptLabel = document.getElementById('excerptLabel');
        var contentLabel = document.getElementById('contentLabel');
        var contentSectionTitle = document.getElementById('contentSectionTitle');
        var previewTitle = document.getElementById('previewTitle');
        var submitButton = document.getElementById('submitButton');
        var readTimeGroup = document.getElementById('readTimeGroup');
        var featuredLabel = document.getElementById('featuredLabel');
        var tagsLabel = document.getElementById('tagsLabel');
        var contentTextarea = document.getElementById('content');
        if (titleEl) titleEl.placeholder = type === 'projects' ? 'Judul proyek atau portfolio...' : type === 'products' ? 'Judul produk...' : 'Judul artikel...';
        if (titleLabel) titleLabel.textContent = type === 'products' ? 'Judul Produk' : type === 'projects' ? 'Judul Portfolio' : 'Judul Artikel';
        if (excerptEl) excerptEl.placeholder = type === 'projects' ? 'Ringkasan proyek untuk tampilan portfolio...' : type === 'products' ? 'Ringkasan produk untuk daftar produk...' : 'Tuliskan ringkasan singkat artikel Anda...';
        if (excerptLabel) excerptLabel.textContent = type === 'products' ? 'Ringkasan Produk' : type === 'projects' ? 'Ringkasan Portfolio' : 'Ringkasan Singkat';
        if (contentLabel) contentLabel.textContent = type === 'products' ? 'Deskripsi Detail Produk' : type === 'projects' ? 'Deskripsi Portfolio' : 'Isi Artikel';
        if (contentSectionTitle) contentSectionTitle.textContent = type === 'products' ? '✍️ Deskripsi Produk' : type === 'projects' ? '✍️ Konten Portfolio' : '✍️ Konten Artikel';
        if (previewTitle) previewTitle.textContent = type === 'products' ? 'Preview Produk (Live)' : type === 'projects' ? 'Preview Portfolio (Live)' : 'Preview Artikel (Live)';
        if (submitButton) submitButton.textContent = type === 'products' ? '💾 Simpan Produk' : type === 'projects' ? '💾 Simpan Portfolio' : '💾 Simpan Artikel';
        if (readTimeGroup) readTimeGroup.style.display = type === 'posts' ? 'block' : 'none';
        if (featuredLabel) featuredLabel.textContent = type === 'products' ? '⭐ Jadikan Produk Unggulan' : type === 'projects' ? '⭐ Jadikan Portfolio Unggulan' : '⭐ Jadikan Artikel Unggulan';
        if (tagsLabel) tagsLabel.textContent = type === 'products' ? 'Keunggulan / Tag Produk' : type === 'projects' ? 'Tag Portfolio' : 'Tag (Pisahkan dengan koma)';
        if (contentTextarea) contentTextarea.placeholder = type === 'products' ? 'Tuliskan deskripsi detail produk. Jika tidak ada tag, sistem akan otomatis membuat daftar keunggulan dari isi ini.' : type === 'projects' ? 'Tuliskan deskripsi portfolio lengkap...' : 'Tuliskan konten artikel Anda di sini... (mendukung HTML dan Markdown)';
        loadContent();
      }

      // Load content
      async function loadContent() {
        try {
          var container = document.getElementById(getContainerId());
          if (container) container.innerHTML = '<div class="loading">⏳ Memuat ' + getContentLabel(contentType) + '...</div>';
          var resp = await fetch(apiMap[contentType]);
          if (!resp.ok) {
            var err = await resp.json().catch(function(){ return { error: 'Unknown error' }; });
            console.error('Error loading content:', err);
            if (container) container.innerHTML = '<div class="loading">❌ Gagal memuat ' + getContentLabel(contentType) + ': ' + (err.error || 'server error') + '</div>';
            return;
          }
          var items = await resp.json();
          if (!Array.isArray(items)) {
            console.error('Unexpected response:', items);
            if (container) container.innerHTML = '<div class="loading">❌ Unexpected server response</div>';
            return;
          }
          displayContent(items);
        } catch (e) {
          console.error('Error loading content:', e);
          var c = document.getElementById(getContainerId()); if (c) c.innerHTML = '<div class="loading">❌ Gagal memuat ' + getContentLabel(contentType) + '</div>';
        }
      }

      function parseTags(tags) {
        if (!tags) return [];
        try {
          var parsed = typeof tags === 'string' ? JSON.parse(tags) : tags;
          return Array.isArray(parsed) ? parsed : String(tags).split(',').map(function (t) { return t.trim(); }).filter(Boolean);
        } catch (e) {
          return String(tags).split(',').map(function (t) { return t.trim(); }).filter(Boolean);
        }
      }

      function parseJsonField(value, fallback) {
        if (!value) return fallback;
        if (typeof value === 'string') {
          try { return JSON.parse(value); } catch (e) {}
          return String(value).split(',').map(function (item) { return item.trim(); }).filter(Boolean);
        }
        return value;
      }

      function displayContent(items) {
        var container = document.getElementById(getContainerId()); if (!container) return;
        if (!items || items.length === 0) {
          container.innerHTML = '<div class="loading">' + getListEmptyMessage() + '</div>';
          return;
        }

        container.innerHTML = items.map(function (item) {
          var dateStr = '—';
          if (contentType === 'posts' || contentType === 'products') {
            try { var d = new Date(item.published_at); if (!isNaN(d.getTime())) dateStr = d.toLocaleDateString('id-ID'); } catch (e) {}
          } else if (contentType === 'projects') {
            dateStr = item.year ? String(item.year) : '—';
          }
          var label = contentType === 'projects' ? (item.summary || '') : (item.excerpt || '');
          var badge = item.featured || item.is_featured ? '<span class="post-card-badge">⭐ Unggulan</span>' : '';
          var imgUrl = item.cover_image || item.cover || '';
          var imgHtml = imgUrl ? '<img src="' + imgUrl + '" alt="' + (item.title || 'Gambar konten') + '" class="post-card-image" />' : '';
          var idEsc = JSON.stringify(item.id);
          return '\n        <div class="post-card">' + imgHtml + '\n          <h3 class="post-card-title">' + (item.title || '') + '</h3>\n          <div class="post-card-meta">\n            <span>' + (contentType === 'projects' ? '📅 ' + dateStr : '📅 ' + dateStr) + '</span>\n            ' + badge + '\n          </div>\n          <p style="color: rgba(255,255,255,0.75); font-size: 0.95rem; min-height: 3rem;">' + escapeHtml(label) + '</p>\n          <div class="post-card-actions">\n            <button class="btn btn-secondary" style="flex: 1; margin-right:6px;" onclick="window.viewContent(\'' + contentType + '\',' + idEsc + ')">👁️ Lihat</button>\n            <button class="btn btn-secondary" style="flex: 1;" onclick="window.editContent(\'' + contentType + '\',' + idEsc + ')">✏️ Edit</button>\n            <button class="btn btn-danger" style="flex: 1;" onclick="window.deleteContentConfirm(\'' + contentType + '\',' + idEsc + ')">🗑️ Hapus</button>\n          </div>\n        </div>\n      ';
        }).join('');
      }

      function buildProductContentFallback(content, tags) {
        var base = [];
        var cleaned = String(content || '').split(/\n|\.|;|,/).map(function (item) { return item.replace(/<[^>]+>/g, '').trim(); }).filter(Boolean);
        var tagsList = parseTags(tags || '').map(function (item) { return item.trim(); }).filter(Boolean);
        if (cleaned.length > 0) base = base.concat(cleaned.slice(0, 4));
        if (tagsList.length > 0) base = base.concat(tagsList.slice(0, 4));
        if (base.length === 0) base = ['Paket lengkap', 'Kustomisasi tersedia', 'Pengiriman cepat'];
        return base.slice(0, 6).join('\n');
      }

      window.editContent = async function (type, id) {
        try {
          setContentType(type);
          var resp = await fetch('/api/' + type + '/' + id);
          if (!resp.ok) { alert('❌ Gagal memuat ' + getContentLabel(type)); return; }
          var item = await resp.json();
          if (document.getElementById('contentId')) document.getElementById('contentId').value = item.id || '';
          if (document.getElementById('title')) document.getElementById('title').value = item.title || '';
          if (document.getElementById('slug')) document.getElementById('slug').value = item.slug || '';
          if (document.getElementById('excerpt')) document.getElementById('excerpt').value = item.summary || item.excerpt || '';
          if (document.getElementById('content')) document.getElementById('content').value = item.content || item.description || '';
          if (document.getElementById('coverImage')) document.getElementById('coverImage').value = item.cover_image || item.cover || '';
          if (document.getElementById('featured')) document.getElementById('featured').checked = item.featured === 1 || item.is_featured === 1 || item.featured === true;
          if (document.getElementById('readTime')) document.getElementById('readTime').value = item.read_time || '';
          if (document.getElementById('tags')) {
            var parsedTags = parseTags(item.tags || item.tech || []);
            document.getElementById('tags').value = parsedTags.join(', ');
          }
          if (document.getElementById('role')) document.getElementById('role').value = item.role || '';
          if (document.getElementById('year')) document.getElementById('year').value = item.year || '';
          if (document.getElementById('tech')) document.getElementById('tech').value = Array.isArray(item.tech) ? item.tech.join(', ') : item.tech || '';
          if (document.getElementById('client')) document.getElementById('client').value = item.client || '';
          if (document.getElementById('duration')) document.getElementById('duration').value = item.duration || '';
          if (document.getElementById('links')) document.getElementById('links').value = item.links ? (typeof item.links === 'string' ? item.links : JSON.stringify(item.links)) : '';
          if (document.getElementById('galleryImages')) {
            var gallery = parseJsonField(item.images, []);
            document.getElementById('galleryImages').value = Array.isArray(gallery) ? gallery.join('\n') : String(gallery);
          }
          if (document.getElementById('productLink')) document.getElementById('productLink').value = item.link || '';
          if (document.getElementById('price')) document.getElementById('price').value = item.price || '';
          if (document.getElementById('productHighlights')) {
            var highlights = '';
            if (item.tags) {
              highlights = parseTags(item.tags).join('\n');
            }
            document.getElementById('productHighlights').value = highlights;
          }
          if (previewImage && (item.cover_image || item.cover)) { previewImage.src = item.cover_image || item.cover; if (imagePreview) imagePreview.style.display = 'block'; }
          var createTab = document.querySelector('[data-tab="create"]'); if (createTab) createTab.click(); window.scrollTo({ top: 0, behavior: 'smooth' });
        } catch (e) { alert('❌ Error memuat ' + getContentLabel(type) + ': ' + e); }
      };

      window.deleteContentConfirm = async function (type, id) {
        if (!confirm('⚠️ Yakin ingin menghapus ' + getContentLabel(type) + ' ini?')) return;
        try {
          var resp = await fetch('/api/' + type + '/' + id, { method: 'DELETE' });
          if (resp.ok) { alert('✅ ' + getContentLabel(type).charAt(0).toUpperCase() + getContentLabel(type).slice(1) + ' berhasil dihapus!'); loadContent(); } else { alert('❌ Error menghapus ' + getContentLabel(type)); }
        } catch (e) { alert('❌ Error: ' + e); }
      };

      window.viewContent = async function (type, id) {
        try {
          var resp = await fetch('/api/' + type + '/' + id);
          if (!resp.ok) { alert('❌ Gagal memuat ' + getContentLabel(type)); return; }
          var item = await resp.json();
          var bodyEl = document.getElementById('modalBody');
          var raw = item.content || item.description || '';
          var html = '';
          if (/<[^>]+>/m.test(raw)) html = raw; else html = renderMarkdown(raw);
          var injected = injectHeadingIds(html);
          var contentHtml = injected.contentHtml;
          var toc = injected.toc;
          var metaFields = [];
          if (type === 'posts') {
            metaFields.push('📅 ' + (item.published_at ? (new Date(item.published_at)).toLocaleDateString('id-ID') : '—'));
          } else if (type === 'projects') {
            metaFields.push(item.year ? '📅 ' + item.year : '📅 —');
            if (item.role) metaFields.push('🎯 ' + item.role);
            if (item.client) metaFields.push('👥 ' + item.client);
          } else if (type === 'products') {
            metaFields.push(item.price ? '💰 ' + item.price : '💰 —');
            if (item.link) metaFields.push('🔗 ' + item.link);
          }
          if (item.featured || item.is_featured) metaFields.push('⭐ Unggulan');
          var metaHtml = '<div class="admin-post-detail__meta">' + metaFields.map(function (field) { return '<span>' + escapeHtml(field) + '</span>'; }).join('') + '</div>';
          var heroHtml = (item.cover_image || item.cover) ? '<div class="admin-post-detail__hero"><img src="' + (item.cover_image || item.cover) + '" alt="' + (item.title || 'Gambar konten') + '" /></div>' : '';
          var excerptHtml = (item.summary || item.excerpt) ? '<p class="admin-post-detail__excerpt">' + escapeHtml(item.summary || item.excerpt || '') + '</p>' : '';
          var sidebar = '<aside class="admin-post-detail__sidebar">' +
            '<div class="toc"><h4>Di halaman ini</h4>';
          if (!toc || toc.length === 0) {
            sidebar += '<p>Tidak ada heading</p>';
          } else {
            sidebar += '<ul>' + toc.map(function (t) { return '<li><a href="#' + t.id + '">' + t.text + '</a></li>'; }).join('') + '</ul>';
          }
          sidebar += '</div></aside>';
          var detailHtml = '<article class="admin-post-detail">' +
            '<div class="admin-post-detail__header">' +
            '<h1 class="admin-post-detail__title">' + escapeHtml(item.title || '') + '</h1>' +
            metaHtml +
            excerptHtml +
            '</div>' +
            heroHtml +
            '<div class="admin-post-detail__content-wrapper">' +
            '<div class="admin-post-detail__content">' + contentHtml + '</div>' +
            sidebar +
            '</div>' +
            '</article>';
          if (bodyEl) bodyEl.innerHTML = detailHtml;
          var modal = document.getElementById('postModal'); if (modal) modal.style.display = 'flex';
        } catch (e) { alert('❌ Error memuat detail: ' + e); }
      };

      var modalClose = document.getElementById('modalCloseBtn'); if (modalClose) modalClose.addEventListener('click', function () { var m = document.getElementById('postModal'); if (m) m.style.display = 'none'; });

      // Form submission
      var contentForm = document.getElementById('contentForm');
      if (contentForm) {
        contentForm.addEventListener('submit', async function (e) {
          e.preventDefault();
          var contentIdEl = document.getElementById('contentId'); var contentId = contentIdEl ? contentIdEl.value : '';
          var titleEl = document.getElementById('title'); var slugEl = document.getElementById('slug'); var excerptEl = document.getElementById('excerpt'); var contentEl = document.getElementById('content'); var coverEl = document.getElementById('coverImage'); var featEl = document.getElementById('featured'); var tagsEl = document.getElementById('tags');
          var data = {
            title: titleEl ? titleEl.value : '',
            slug: (slugEl && slugEl.value) ? slugEl.value : (titleEl ? titleEl.value.toLowerCase().replace(/\s+/g, '-') : ''),
            excerpt: excerptEl ? excerptEl.value : '',
            content: contentEl ? contentEl.value : '',
            cover_image: coverEl ? (coverEl.value || null) : null,
            is_featured: featEl ? featEl.checked : false,
            tags: tagsEl ? tagsEl.value : '',
          };
          if (contentType === 'posts') {
            var readEl = document.getElementById('readTime');
            data.read_time = readEl ? (parseInt(readEl.value) || 5) : 5;
          }
          if (contentType === 'projects') {
            var roleEl = document.getElementById('role'); var yearEl = document.getElementById('year'); var techEl = document.getElementById('tech'); var clientEl = document.getElementById('client'); var durationEl = document.getElementById('duration'); var linksEl = document.getElementById('links'); var galleryEl = document.getElementById('galleryImages');
            data.summary = excerptEl ? excerptEl.value : '';
            data.description = contentEl ? contentEl.value : '';
            data.role = roleEl ? roleEl.value : '';
            data.year = yearEl ? parseInt(yearEl.value) || null : null;
            data.tech = techEl ? techEl.value : '';
            data.client = clientEl ? clientEl.value : '';
            data.duration = durationEl ? durationEl.value : '';
            data.links = linksEl ? linksEl.value : '';
            data.images = galleryEl ? galleryEl.value.split('\n').map(function (line) { return line.trim(); }).filter(Boolean) : [];
          }
          if (contentType === 'products') {
            var productLinkEl = document.getElementById('productLink'); var priceEl = document.getElementById('price'); var highlightsEl = document.getElementById('productHighlights');
            data.link = productLinkEl ? productLinkEl.value : '';
            data.price = priceEl ? priceEl.value : '';
            var normalizedHighlights = highlightsEl ? highlightsEl.value.split(/\n|,/).map(function (line) { return line.trim(); }).filter(Boolean) : [];
            if (normalizedHighlights.length > 0) {
              data.tags = normalizedHighlights.join(', ');
            } else {
              data.tags = (tagsEl ? tagsEl.value : '') || '';
            }
            if (!data.content || !String(data.content).trim()) {
              data.content = 'Detail produk SeminarKit.';
            }
            if (!data.excerpt || !String(data.excerpt).trim()) {
              data.excerpt = 'Produk SeminarKit yang siap dipakai.';
            }
            if (!data.tags || !String(data.tags).trim()) {
              data.tags = buildProductContentFallback(data.content, '');
            }
          }
          try {
            var method = contentId ? 'PUT' : 'POST';
            var url = contentId ? '/api/' + contentType + '/' + contentId : '/api/' + contentType;
            var resp = await fetch(url, { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
            if (resp.ok) {
              alert('✅ ' + getContentLabel(contentType).charAt(0).toUpperCase() + getContentLabel(contentType).slice(1) + ' berhasil ' + (contentId ? 'diperbarui' : 'dibuat') + '!');
              contentForm.reset();
              if (document.getElementById('contentId')) document.getElementById('contentId').value = '';
              if (imagePreview) imagePreview.style.display = 'none';
              await loadContent();
              var listTab = document.querySelector('[data-tab="list"]'); if (listTab) listTab.click();
              window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
              var err = await resp.json().catch(function(){ return { error: 'save failed' }; });
              alert('❌ Error: ' + (err.error || 'save failed'));
            }
          } catch (e) { alert('❌ Error menyimpan ' + getContentLabel(contentType) + ': ' + e); }
        });
      }

      // Initialize
      initUploadArea();
      initEditorToolbar();
      document.querySelectorAll('.type-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          setContentType(btn.dataset.type);
        });
      });
      setContentType('dashboard');
    });
  </script>
</BaseLayout>
