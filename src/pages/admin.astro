  <!-- Post detail modal -->
  <div id="postModal" class="modal" style="display:none;">
    <div class="modal-backdrop" onclick="document.getElementById('postModal').style.display='none'"></div>
    <div class="modal-dialog">
      <button id="modalCloseBtn" class="btn btn-logout modal-close">✕</button>
      <div id="modalBody" class="modal-body" style="margin-top:8px"></div>
    </div>
  </div>

  <script>
    // @ts-nocheck
    document.addEventListener('DOMContentLoaded', function () {
      // Tab switching
      document.querySelectorAll('.tab-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var tabName = btn.dataset.tab;
          document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
          document.querySelectorAll('.tab-content').forEach(function (t) { t.classList.remove('active'); });
          btn.classList.add('active');
          var tabEl = document.getElementById(tabName + '-tab');
          if (tabEl) tabEl.classList.add('active');
        });
      });

      // Elements
      var uploadArea = document.getElementById('uploadArea');
      var fileInput = document.getElementById('coverImageUpload');
      var imagePreview = document.getElementById('coverImagePreview');
      var previewImage = document.getElementById('previewImage');
      var coverImageInput = document.getElementById('coverImage');
      var uploadProgress = document.getElementById('uploadProgress');

      // Image upload handling
      function initUploadArea() {
        if (!uploadArea || !fileInput) return;
        uploadArea.addEventListener('click', function () { fileInput.click(); });
        uploadArea.addEventListener('dragover', function (e) { e.preventDefault(); uploadArea.classList.add('dragover'); });
        uploadArea.addEventListener('dragleave', function () { uploadArea.classList.remove('dragover'); });
        uploadArea.addEventListener('drop', function (e) {
          e.preventDefault(); uploadArea.classList.remove('dragover');
          var files = e.dataTransfer && e.dataTransfer.files;
          if (files && files[0]) handleFileSelect(files[0]);
        });

        fileInput.addEventListener('change', function (e) {
          var files = e.target && e.target.files;
          if (files && files[0]) handleFileSelect(files[0]);
        });
      }

      // Editor toolbar: apply simple markdown/HTML formatting
      function applyEditorFormat(action) {
        var ta = document.getElementById('content'); if (!ta) return;
        var start = ta.selectionStart || 0; var end = ta.selectionEnd || 0; var val = ta.value || '';
        var selected = val.slice(start, end) || '';
        var before = val.slice(0, start); var after = val.slice(end);

        function replaceRange(newText, selectStartOffset, selectEndOffset) {
          ta.value = before + newText + after;
          var newStart = before.length + (selectStartOffset || 0);
          var newEnd = before.length + newText.length - (selectEndOffset || 0);
          ta.focus(); ta.setSelectionRange(newStart, newEnd);
        }

        if (action === 'bold') {
          var wrapped = '**' + (selected || 'bold text') + '**';
          replaceRange(wrapped, 2, 2);
        } else if (action === 'italic') {
          var wrapped = '*' + (selected || 'italic text') + '*';
          replaceRange(wrapped, 1, 1);
        } else if (action === 'h1' || action === 'h2' || action === 'h3') {
          var prefix = action === 'h1' ? '# ' : (action === 'h2' ? '## ' : '### ');
          var lineStart = val.lastIndexOf('\n', start - 1) + 1;
          var lineEnd = val.indexOf('\n', end);
          if (lineEnd === -1) lineEnd = val.length;
          var line = val.slice(lineStart, lineEnd);
          var headingPattern = /^(#{1,3})\s+/;
          if (headingPattern.test(line)) {
            var newLine = line.replace(headingPattern, '');
            ta.value = val.slice(0, lineStart) + newLine + val.slice(lineEnd);
            ta.setSelectionRange(lineStart, lineStart + newLine.length);
          } else {
            var newLine = prefix + (selected || line || 'Heading');
            ta.value = val.slice(0, lineStart) + newLine + val.slice(lineEnd);
            ta.setSelectionRange(lineStart + prefix.length, lineStart + prefix.length + (selected || line || 'Heading').length);
          }
        } else if (action === 'link') {
          var url = prompt('URL tujuan (termasuk https://):', 'https://');
          if (!url) return;
          var text = selected || prompt('Teks link:', 'link text') || 'link';
          var wrapped = '[' + text + '](' + url + ')';
          replaceRange(wrapped, 1 + text.length + 1, 1 + url.length + 1);
        } else if (action === 'code') {
          if (selected.indexOf('\n') !== -1) {
              var wrapped = '```\n' + selected + '\n```';
            replaceRange(wrapped, 4, 3);
          } else {
            var wrapped = '`' + (selected || 'code') + '`';
            replaceRange(wrapped, 1, 1);
          }
        }
      }

      function initEditorToolbar() {
        var buttons = document.querySelectorAll('.editor-btn');
        buttons.forEach(function (btn) {
          btn.addEventListener('click', function () {
            var action = btn.getAttribute('data-action');
            applyEditorFormat(action);
          });
        });
        var headingSelect = document.getElementById('headingSelect');
        if (headingSelect) {
          headingSelect.addEventListener('change', function () {
            applyEditorFormat(headingSelect.value);
            headingSelect.value = '';
          });
        }
        var previewToggle = document.getElementById('previewToggle');
        if (previewToggle) previewToggle.addEventListener('click', function () {
          togglePreview();
        });
      }

      // Simple markdown -> HTML renderer (minimal)
      function renderMarkdown(md) {
        if (!md) return '';
        // If content already contains HTML tags, treat as HTML
        if (/<[^>]+>/m.test(md)) return md;
        var html = md;
        // code blocks
        html = html.replace(/```([\s\S]*?)```/g, function (m, code) { return '<pre><code>' + escapeHtml(code) + '</code></pre>'; });
        // headings
        html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
        html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
        html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');
        // bold/italic
        html = html.replace(/\*\*(.*?)\*\*/gim, '<strong>$1</strong>');
        html = html.replace(/\*(.*?)\*/gim, '<em>$1</em>');
        // inline code
        html = html.replace(/`([^`]+)`/gim, '<code>$1</code>');
        // links
        html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/gim, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
        // paragraphs (double newline)
        html = html.split(/\n\n+/).map(function (p) { return '<p>' + p.replace(/\n/g, '<br/>') + '</p>'; }).join('\n');
        return html;
      }

      function escapeHtml(str) {
        return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }

      // slugify headings for ids
      function slugify(text) {
        return String(text)
          .toLowerCase()
          .trim()
          .replace(/<[^>]+>/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
      }

      // Inject ids into H2/H3 headings and build TOC
      function injectHeadingIds(html) {
        var toc = [];
        var content = html.replace(/<(h2|h3)([^>]*)>(.*?)<\/\1>/gi, function (m, tag, attrs, inner) {
          var id = slugify(inner);
          try { toc.push({ id: id, text: inner.replace(/<[^>]+>/g, '') }); } catch (e) {}
          return '<' + tag + (attrs || '') + ' id="' + id + '">' + inner + '</' + tag + '>';
        });
        return { contentHtml: content, toc: toc };
      }

      function renderPreview(content) {
        var panel = document.getElementById('previewPanel');
        var out = document.getElementById('previewContent');
        if (!out) return;
        out.innerHTML = renderMarkdown(content || '');
