      async function handleFileSelect(file) {
        var accepted = ['jpg','jpeg','png','webp','gif','avif'];
        var ext = (file.name.split('.').pop() || '').toLowerCase();
        var isImageType = file.type && file.type.indexOf('image/') === 0;
        if (!isImageType && accepted.indexOf(ext) === -1) { alert('⚠️ Silakan pilih file gambar (JPG, PNG, WebP, GIF, AVIF)'); return; }
        if (file.size > 5 * 1024 * 1024) { alert('⚠️ Ukuran gambar maksimal 5MB'); return; }
        if (uploadProgress) uploadProgress.style.display = 'block';
        var fd = new FormData(); fd.append('file', file);
        try {
          var resp = await fetch('/api/upload', { method: 'POST', body: fd });
          if (resp.ok) {
            var data = await resp.json();
            if (coverImageInput) coverImageInput.value = data.url || '';
            if (previewImage) previewImage.src = data.url || '';
            if (imagePreview) imagePreview.style.display = 'block';
            if (uploadProgress) uploadProgress.style.display = 'none';
          } else {
            var err = await resp.json().catch(function(){ return { error: 'Upload failed' }; });
            alert('❌ Error: ' + (err.error || 'Upload failed'));
          }
        } catch (e) { alert('❌ Gagal mengunggah gambar: ' + e); }
      }

