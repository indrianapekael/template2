---
import BaseLayout from '@/layouts/BaseLayout.astro';
import siteConfig from '@/site.config';
export const prerender = true;
---

<BaseLayout title="Admin - Kelola Konten">
  <main class="admin-main">
    <div class="admin-shell">
      <aside class="admin-sidebar">
        <div class="sidebar-brand">
          <div class="brand-mark">PC</div>
          <div>
            <p class="brand-name">ProCleaning</p>
            <p class="brand-caption">Admin Console</p>
          </div>
        </div>

        <nav class="sidebar-nav" role="tablist" aria-label="Jenis Konten">
          <button class="sidebar-link type-btn active" type="button" data-type="dashboard" role="tab" aria-selected="true">
            <span class="tab-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13.5 12 5l8 8.5"></path><path d="M6.5 12.5V19h11V12.5"></path></svg>
            </span>
            <span>Dashboard</span>
          </button>
          <button class="sidebar-link type-btn" type="button" data-type="posts" role="tab" aria-selected="false">
            <span class="tab-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h10l4 4v12H5z"></path><path d="M15 4v5h5"></path><path d="M8 13h8"></path><path d="M8 17h5"></path></svg>
            </span>
            <span>Blog</span>
          </button>
          <button class="sidebar-link type-btn" type="button" data-type="projects" role="tab" aria-selected="false">
            <span class="tab-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"></rect><path d="M8 8h8"></path><path d="M8 12h8"></path><path d="M8 16h5"></path></svg>
            </span>
            <span>Portfolio</span>
          </button>
          <button class="sidebar-link type-btn" type="button" data-type="products" role="tab" aria-selected="false">
            <span class="tab-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="20" r="1"></circle><circle cx="18" cy="20" r="1"></circle><path d="M3 4h2l2.4 10.6a1 1 0 0 0 1 .8h8.8a1 1 0 0 0 1-.8L18 7H7"></path></svg>
            </span>
            <span>Produk</span>
          </button>
        </nav>

        <div class="sidebar-footer">
          <a class="sidebar-link" href="/">View Website</a>
          <button class="btn btn-logout btn-large">Logout</button>
        </div>
      </aside>

      <section class="admin-panel">
        <div class="admin-header-panel">
          <div class="header-content">
            <p class="eyebrow">Admin Console</p>
            <h1 class="header-title">Kelola Konten & Informasi Situs</h1>
            <p class="header-subtitle">Pilih menu di sebelah kiri untuk memantau dashboard, blog, portfolio, dan produk.</p>
          </div>

          <div class="page-actions" role="tablist" aria-label="Aksi Konten">
            <button class="tab-btn active" type="button" data-tab="list">
              <span class="tab-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5" width="16" height="14" rx="2"></rect><path d="M8 9h8"></path><path d="M8 13h5"></path></svg>
              </span>
              <span>Daftar</span>
            </button>
            <button class="tab-btn" type="button" data-tab="create">
              <span class="tab-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
              </span>
              <span>Buat Baru</span>
            </button>
          </div>
        </div>

        <div class="panel-body">
          <div class="tab-content-wrapper">
            <div id="dashboard-tab" class="tab-content active">
              <div class="dashboard-grid">
                <div class="dashboard-card">
                  <h2>Informasi Situs</h2>
                  <p><strong>Nama:</strong> {siteConfig.name}</p>
                  <p><strong>Deskripsi:</strong> {siteConfig.description}</p>
                  <p><strong>URL:</strong> <a href="http://localhost:3000/" target="_blank" rel="noopener noreferrer">http://localhost:3000/</a></p>
                  <p><strong>Blog aktif:</strong> {siteConfig.features.blog ? 'Ya' : 'Tidak'}</p>
                  <p><strong>Portfolio aktif:</strong> {siteConfig.features.portfolio ? 'Ya' : 'Tidak'}</p>
                </div>

                <div class="dashboard-card" id="dashboardStats">
                  <h2>Statistik Konten</h2>
                  <div class="stat-item"><span>Artikel</span><strong id="statsPosts">⏳</strong></div>
                  <div class="stat-item"><span>Portfolio</span><strong id="statsProjects">⏳</strong></div>
                  <div class="stat-item"><span>Produk</span><strong id="statsProducts">⏳</strong></div>
                </div>


                <div class="dashboard-card dashboard-card-compact dashboard-card-full" id="dashboardLatest">
                  <div class="dashboard-card-header">
                    <h2>Update Konten Terbaru</h2>
                    <span class="dashboard-card-pill">Ringkas</span>
                  </div>
                  <div class="dashboard-latest-stack">
                    <div class="dashboard-latest-group">
                      <h3>Artikel</h3>
                      <ol id="latestPosts" class="dashboard-latest-list"><li>⏳ Memuat...</li></ol>
                    </div>
                    <div class="dashboard-latest-group">
                      <h3>Portfolio</h3>
                      <ol id="latestProjects" class="dashboard-latest-list"><li>⏳ Memuat...</li></ol>
                    </div>
                    <div class="dashboard-latest-group">
                      <h3>Produk</h3>
                      <ol id="latestProducts" class="dashboard-latest-list"><li>⏳ Memuat...</li></ol>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div id="list-tab" class="tab-content">
              <div id="contentList" class="posts-grid">
                <div class="loading">⏳ Memuat konten...</div>
              </div>
            </div>

            <div id="create-tab" class="tab-content">
              <div class="form-container">
                <form id="contentForm" class="post-form">
                  <input type="hidden" id="contentId" />

                  <div class="form-section">
                    <h2 class="section-title">📄 Informasi Dasar</h2>
                    
                    <div class="form-group">
                      <label for="title" class="form-label">
                        <span class="label-text" id="titleLabel">Judul Artikel</span>
                        <span class="required">*</span>
                      </label>
                      <input 
                        type="text" 
                        id="title" 
                        name="title" 
                        class="form-input"
                        placeholder="Masukkan judul artikel..." 
                        required 
                      />
                    </div>

                    <div class="form-group">
                      <label for="slug" class="form-label">
                        <span class="label-text">Slug URL</span>
                        <span class="required">*</span>
                      </label>
                      <input 
                        type="text" 
                        id="slug" 
                        name="slug" 
                        class="form-input"
                        placeholder="URL-friendly slug (auto-generate dari judul)" 
                        required 
                      />
                    </div>

                    <div class="form-group">
                      <label for="excerpt" class="form-label">
                        <span class="label-text" id="excerptLabel">Ringkasan Singkat</span>
                        <span class="required">*</span>
                      </label>
                      <textarea 
                        id="excerpt" 
                        name="excerpt" 
                        class="form-textarea"
                        rows="3" 
                        placeholder="Tuliskan ringkasan singkat konten..."
                        required
                      ></textarea>
                    </div>

                    <div class="form-section type-section projects-only" style="display:none;">
                      <h2 class="section-title">🏗️ Detail Portfolio</h2>
                      <div class="form-row">
                        <div class="form-group">
                          <label for="role" class="form-label">
                            <span class="label-text">Peran</span>
                          </label>
                          <input type="text" id="role" name="role" class="form-input" placeholder="Contoh: Product Designer" />
                        </div>
                        <div class="form-group">
                          <label for="year" class="form-label">
                            <span class="label-text">Tahun</span>
                          </label>
                          <input type="number" id="year" name="year" class="form-input" min="1900" max="2100" placeholder="2025" />
                        </div>
                      </div>

                      <div class="form-group">
                        <label for="tech" class="form-label">
                          <span class="label-text">Teknologi</span>
                        </label>
                        <input type="text" id="tech" name="tech" class="form-input" placeholder="Astro, Tailwind, TypeScript" />
                      </div>

                      <div class="form-row">
                        <div class="form-group">
                          <label for="client" class="form-label">
                            <span class="label-text">Klien</span>
                          </label>
                          <input type="text" id="client" name="client" class="form-input" placeholder="Nama klien atau brand" />
                        </div>
                        <div class="form-group">
                          <label for="duration" class="form-label">
                            <span class="label-text">Durasi</span>
                          </label>
                          <input type="text" id="duration" name="duration" class="form-input" placeholder="3 bulan, MVP, dsb." />
                        </div>
                      </div>

                    </div>

                    <div class="form-section type-section products-only" style="display:none;">
                      <h2 class="section-title">🛍️ Detail Produk</h2>
                      <div class="form-row">
                        <div class="form-group">
                          <label for="productLink" class="form-label">
                            <span class="label-text">Link Produk</span>
                          </label>
                          <input type="url" id="productLink" name="productLink" class="form-input" placeholder="https://example.com/product" />
                        </div>
                        <div class="form-group">
                          <label for="price" class="form-label">
                            <span class="label-text">Harga</span>
                          </label>
                          <input type="text" id="price" name="price" class="form-input" placeholder="Gratis, $99, dst." />
                        </div>
                      </div>

                      <div class="form-group">
                        <label for="productHighlights" class="form-label">
                          <span class="label-text">Keunggulan / Fitur Produk</span>
                        </label>
                        <textarea id="productHighlights" name="productHighlights" class="form-textarea" rows="4" placeholder="Tulis satu keunggulan per baris, misalnya: Paket lengkap, Bisa kustom, Pengiriman cepat"></textarea>
                        <small style="display:block; margin-top:6px; color: rgba(255,255,255,0.7);">Jika kosong, sistem akan otomatis membuat daftar keunggulan dari isi deskripsi dan tag.</small>
                      </div>
                    </div>
                  </div>

                  <div class="form-section">
                    <h2 class="section-title" id="contentSectionTitle">✍️ Konten Artikel</h2>
                    
                    <div class="form-group">
                      <label for="content" class="form-label">
                        <span class="label-text" id="contentLabel">Isi Artikel</span>
                        <span class="required">*</span>
                      </label>
                        <div class="editor-toolbar" role="toolbar" aria-label="Editor toolbar">
                          <button type="button" class="editor-btn" data-action="bold">B</button>
                          <button type="button" class="editor-btn" data-action="italic">I</button>
                          <select id="headingSelect" class="editor-select" aria-label="Pilih heading">
                            <option value="">Heading</option>
                            <option value="h1">H1</option>
                            <option value="h2">H2</option>
                            <option value="h3">H3</option>
                          </select>
                          <button type="button" class="editor-btn" data-action="link">Link</button>
                          <button type="button" class="editor-btn" data-action="code">Code</button>
                          <button type="button" class="editor-btn" id="previewToggle">Preview</button>
                        </div>
                        <textarea 
                          id="content" 
                          name="content" 
                          class="form-textarea content-textarea"
                          rows="12" 
                          placeholder="Tuliskan konten artikel Anda di sini... (mendukung HTML dan Markdown)"
                          required
                        ></textarea>
                        <div id="previewPanel" class="preview-panel" style="display:none; margin-top: 12px;">
                          <div class="preview-header">
                            <strong id="previewTitle">Preview Artikel (Live)</strong>
                            <small style="margin-left:8px; color: rgba(255,255,255,0.7);">(Menampilkan HTML/Markdown)</small>
                          </div>
                          <div id="previewContent" class="preview-content" style="padding:16px; background: rgba(255,255,255,0.02); border-radius:8px; max-height:360px; overflow:auto;"></div>
                        </div>
                    </div>
                  </div>

                  <div class="form-section">
                    <h2 class="section-title">🖼️ Gambar Sampul</h2>
                    
                    <div class="form-group">
                      <label for="coverImageUpload" class="form-label">
                        <span class="label-text">Unggah Gambar</span>
                      </label>
                      <div class="upload-area" id="uploadArea">
                        <input 
                          type="file" 
                          id="coverImageUpload" 
                          name="coverImageUpload" 
                          class="file-input"
                          accept="image/*"
                        />
                        <div class="upload-content">
                          <span class="upload-icon">📤</span>
                          <p class="upload-text">Klik atau seret gambar ke sini</p>
                          <small>JPG, PNG, WebP (Max 5MB)</small>
                        </div>
                      </div>
                      <div id="uploadProgress" class="upload-progress" style="display: none;">
                        <div class="progress-bar"></div>
                        <span class="progress-text">Mengunggah...</span>
                      </div>
                    </div>

                    <div id="coverImagePreview" class="image-preview" style="display: none;">
                      <div class="preview-content">
                        <img id="previewImage" src="" alt="Pratinjau gambar konten" />
                        <button type="button" class="btn btn-small btn-danger" id="removeImageBtn">
                          ✕ Hapus Gambar
                        </button>
                      </div>
                    </div>

                    <input type="hidden" id="coverImage" name="coverImage" />
                  </div>

                  <div class="form-section">
                    <h2 class="section-title">⚙️ Pengaturan</h2>

                    <div class="form-row">
                      <div class="form-group" id="readTimeGroup">
                        <label for="readTime" class="form-label">
                          <span class="label-text">Waktu Baca (menit)</span>
                        </label>
                        <input 
                          type="number" 
                          id="readTime" 
                          name="readTime" 
                          class="form-input"
                          min="1" 
                          value="5"
                        />
                      </div>

                      <div class="form-group checkbox-group">
                        <label for="featured" class="checkbox-label">
                          <input 
                            type="checkbox" 
                            id="featured" 
                            name="featured" 
                            class="checkbox-input"
                          />
                          <span class="checkbox-text" id="featuredLabel">⭐ Jadikan Artikel Unggulan</span>
                        </label>
                      </div>
                    </div>

                    <div class="form-group">
                      <label for="tags" class="form-label">
                        <span class="label-text" id="tagsLabel">Tag (Pisahkan dengan koma)</span>
                      </label>
                      <input 
                        type="text" 
                        id="tags" 
                        name="tags" 
                        class="form-input"
                        placeholder="astro, web, tutorial, javascript"
                      />
                    </div>
                  </div>

                  <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-large" id="submitButton">
                      💾 Simpan Artikel
                    </button>
                    <button type="button" id="previewSavedBtn" class="btn btn-secondary btn-large" title="Preview versi tersimpan">
                      📄 Preview Tersimpan
                    </button>
                    <button type="reset" class="btn btn-secondary btn-large">
                      🔄 Bersihkan Form
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <style>
    .admin-main {
      min-height: 100vh;
      background-color: var(--color-bg);
      background-image: 
        radial-gradient(circle at 15% 50%, var(--glass-bg) 0%, transparent 50%),
        radial-gradient(circle at 85% 30%, var(--glass-bg) 0%, transparent 50%);
      padding: var(--space-xl) var(--space-lg);
      position: relative;
      overflow: hidden;
      z-index: 1;
    }

    /* Aurora Background Effects */
    .admin-main::before,
    .admin-main::after {
      content: '';
      position: absolute;
      width: 60vw;
      height: 60vw;
      border-radius: 50%;
      filter: blur(100px);
      z-index: -1;
      opacity: 0.15;
      animation: float 20s infinite ease-in-out alternate;
    }

    .admin-main::before {
      top: -10%;
      left: -10%;
      background: radial-gradient(circle, var(--aurora-1) 0%, transparent 70%);
    }

    .admin-main::after {
      bottom: -20%;
      right: -10%;
      background: radial-gradient(circle, var(--aurora-2) 0%, transparent 70%);
      animation-delay: -10s;
    }

    @keyframes float {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(5%, 10%) scale(1.1); }
    }

    .admin-shell {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: var(--space-lg);
      max-width: 1440px;
      margin: 0 auto;
      position: relative;
    }

    .admin-sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
      padding: var(--space-xl);
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-xl);
      box-shadow: var(--glass-shadow);
      backdrop-filter: blur(var(--glass-blur));
      min-height: calc(100vh - 4rem);
      position: sticky;
      top: var(--space-xl);
    }

    .sidebar-brand {
      display: flex;
      gap: var(--space-md);
      align-items: center;
      padding-bottom: var(--space-lg);
      border-bottom: 1px solid var(--glass-border);
    }

    .brand-mark {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--aurora-1), var(--aurora-2));
      display: grid;
      place-items: center;
      font-weight: 800;
      color: #fff;
      box-shadow: 0 8px 24px var(--color-accent-glass);
      font-size: 1.2rem;
      position: relative;
    }
    
    .brand-mark::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      box-shadow: inset 0 0 0 1px var(--glass-border);
    }

    .brand-name {
      margin: 0;
      font-size: var(--text-lg);
      font-weight: 800;
      color: var(--color-text);
      letter-spacing: -0.02em;
    }

    .brand-caption {
      margin: 2px 0 0;
      color: var(--color-text-muted);
      font-size: var(--text-sm);
      font-weight: 500;
    }

    .sidebar-nav {
      display: grid;
      gap: 8px;
      margin-top: var(--space-md);
    }

    .sidebar-link, .type-btn {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      padding: var(--space-md) var(--space-lg);
      border-radius: var(--radius-md);
      color: var(--color-text-muted);
      text-decoration: none;
      background: transparent;
      border: 1px solid transparent;
      transition: all var(--transition-base);
      font-weight: 600;
      cursor: pointer;
      text-align: left;
      width: 100%;
      font-size: 0.95rem;
    }

    .sidebar-link:hover,
    .type-btn:hover {
      color: var(--color-text);
      background: var(--color-surface);
      transform: translateX(4px);
    }

    .sidebar-link.active,
    .type-btn.active {
      color: var(--color-text);
      background: var(--color-accent-glass);
      border-color: var(--color-accent);
      box-shadow: inset 4px 0 0 var(--color-accent);
    }

    .sidebar-footer {
      margin-top: auto;
      display: grid;
      gap: var(--space-md);
    }
    
    .sidebar-footer .sidebar-link {
       justify-content: center;
       background: var(--color-surface);
       border: 1px solid var(--glass-border);
    }
    
    .sidebar-footer .sidebar-link:hover {
       background: var(--glass-bg);
       transform: translateY(-2px);
    }

    .admin-panel {
      display: flex;
      flex-direction: column;
      gap: var(--space-xl);
      padding: var(--space-2xl);
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-xl);
      box-shadow: var(--glass-shadow);
      backdrop-filter: blur(var(--glass-blur));
    }

    .admin-header-panel {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-lg);
      flex-wrap: wrap;
    }

    .eyebrow {
      margin: 0 0 0.5rem;
      color: var(--color-accent-text);
      font-size: var(--text-sm);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .admin-header-panel .header-title {
      margin: 0;
      font-size: var(--text-4xl);
      font-weight: 800;
      color: var(--color-text);
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    .admin-header-panel .header-subtitle {
      margin: 0.75rem 0 0;
      color: var(--color-text-muted);
      max-width: 600px;
      font-size: var(--text-base);
      line-height: 1.5;
    }

    .panel-body {
      display: grid;
      gap: var(--space-xl);
    }

    .page-actions {
      display: inline-flex;
      background: var(--color-surface);
      padding: 6px;
      border-radius: var(--radius-lg);
      border: 1px solid var(--glass-border);
      gap: 4px;
      width: fit-content;
    }

    .tab-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: calc(var(--radius-lg) - 4px);
      border: 1px solid transparent;
      background: transparent;
      color: var(--color-text-muted);
      font-weight: 600;
      transition: all var(--transition-base);
      cursor: pointer;
      font-size: 0.95rem;
    }

    .tab-icon {
      width: 1.05rem;
      height: 1.05rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .tab-icon svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .tab-btn.active {
      background: var(--color-surface);
      color: var(--color-text);
      box-shadow: 0 4px 12px var(--glass-shadow);
      border-color: var(--glass-border);
    }

    .tab-btn:hover:not(.active) {
      color: var(--color-text);
      background: var(--glass-bg);
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(280px, 1fr));
      gap: var(--space-lg);
      margin-bottom: var(--space-xl);
      align-items: start;
    }

    .dashboard-card {
      padding: var(--space-lg);
      border-radius: var(--radius-xl);
      background: linear-gradient(145deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
      border: 1px solid var(--glass-border);
      box-shadow: 0 14px 34px rgba(0, 0, 0, 0.08);
      min-height: 220px;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .dashboard-card-compact {
      min-height: auto;
      gap: 0.7rem;
    }

